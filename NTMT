local SEEDS_LIST = {"Carrot","Strawberry","Blueberry","Tulip","Tomato","Apple","Bamboo","Corn","Cactus","Pineapple","Mushroom","GreenBean","Banana","Grape","Coconut","Mango","Acorn","Cherry","Sunflower","Lotus","Pomegranate","PoisonApple","DragonFruit","HornedMelon","BabyCactus","GlowMushroom","VenusFlytrap","GhostPepper","MoonBloom","VenomSpitter","DragonBreath"}

local GEARS_LIST = {"CommonWateringCan","CommonSprinkler","Sign","UncommonSprinkler","RareSprinkler","Trowel","BasicTrap","AdvancedShovel","JumpMushroom","SpeedMushroom","SuperWateringCan","LegendarySprinkler","PowerHose","FreezeRay","VineWrapper","RainbowCarpet","Gnome","Wheelbarrow","PlayerMagnet","StrawberrySniper","SuperSprinkler"}

genv.ftgs_AutoBuySeed = false
genv.ftgs_AutoBuyGear = false
local selectedSeeds = {}
local selectedGears = {}
local buyAllSeeds = true
local buyAllGears = true
local buyAmount = 20
local buyInterval = 1.2

local function buySeed(name, amount)
    amount = amount or 20
    pcall(function()
        -- Cố gắng mọi cách
        local GE = game:GetService("ReplicatedStorage"):FindFirstChild("GameEvents")
        if GE then
            local rem = GE:FindFirstChild("Buy_Seed") or GE:FindFirstChild("PurchaseSeed") or GE:FindFirstChild("ShopBuy")
            if rem then
                if rem:IsA("RemoteEvent") then rem:FireServer(name, amount)
                else rem:InvokeServer(name, amount) end
                return
            end
        end
        
        if Networking and Networking.Shop then
            local shop = Networking.Shop
            if shop.BuySeed then shop.BuySeed:Fire(name, amount)
            elseif shop.Buy_Seed then shop.Buy_Seed:Fire(name, amount)
            elseif shop.PurchaseSeed then shop.PurchaseSeed:Fire(name, amount) end
        end
    end)
end

local function buyGear(name, amount)
    amount = amount or 1
    pcall(function()
        local GE = game:GetService("ReplicatedStorage"):FindFirstChild("GameEvents")
        if GE then
            local rem = GE:FindFirstChild("Buy_Gear") or GE:FindFirstChild("PurchaseGear")
            if rem then
                if rem:IsA("RemoteEvent") then rem:FireServer(name, amount)
                else rem:InvokeServer(name, amount) end
                return
            end
        end
        if Networking and Networking.Shop then
            local shop = Networking.Shop
            if shop.BuyGear then shop.BuyGear:Fire(name, amount)
            elseif shop.Buy_Gear then shop.Buy_Gear:Fire(name, amount) end
        end
    end)
end

