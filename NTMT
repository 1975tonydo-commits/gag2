    while task.wait(15) do
        cachePlantAreas()
    end
end)

local function randomPlantSpot()
    if #plantAreas == 0 then cachePlantAreas() end
    if #plantAreas == 0 then return nil end
    plantSpotIndex = plantSpotIndex + 1
    return plantAreas[((plantSpotIndex - 1) % #plantAreas) + 1]
end

