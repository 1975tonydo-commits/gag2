task.spawn(function()
    while true do
        task.wait(collectInterval)
        if genv.ftgs_AutoCollectRainbowGold or genv.ftgs_AutoCollectItemDrop then
            pcall(function()
                if genv.ftgs_AutoCollectRainbowGold then
                    for _, spawn in ipairs(collectRainbowGoldTargets()) do
                        if not genv.ftgs_AutoCollectRainbowGold then break end
                        collectItemWithPrompt(spawn)
                    end
                end
                if genv.ftgs_AutoCollectItemDrop then
                    for _, item in ipairs(Services.Workspace:GetDescendants()) do
                        if isItemDrop(item) then
                            collectItemWithPrompt(item)
                        end
                    end
                end
            end)
        end
    end
end)

task.spawn(function()
    while true do
        if genv.ftgs_AntiSteal then
            pcall(function()
                local stealers = findStealersInPlot()
                if #stealers > 0 then
                    local myRoot = getRoot(LocalPlayer)
                    local origCF = myRoot and myRoot.CFrame
                    for _, p in ipairs(stealers) do
                        if not genv.ftgs_AntiSteal then break end
                        attackPlayer(p)
                    end
                    if origCF and myRoot then pcall(function() myRoot.CFrame = origCF end) end
                end
            end)
            task.wait(0.05)
        else
            task.wait(0.25)
        end
    end
end)

task.spawn(function()
    while true do
        task.wait(math.max(60, webhookIntervalMinutes * 60))
        if webhookEnabled and webhookUrl ~= "" then pcall(sendWebhook, "auto") end
    end
end)

task.spawn(function()
    while true do
        if tostring(game.JobId) ~= tostring(lastKnownJobId) then
            lastKnownJobId = game.JobId
            petFoundOnServer = false
            task.wait(3)
        end
        if genv.ftgs_AutoFindPet and not petFoundOnServer then
            local found = scanAndFindPet(false)
            if found then
                genv.ftgs_AutoFindPet = false
            else
                task.wait(1.5)
                if genv.ftgs_AutoFindPet and not petFoundOnServer then
                    local names = table.concat(getFindPetList(), ", ")
                    notify("Find Pet", "No [" .. names .. "] here - hopping...", "shuffle", 2)
                    hopRandomServer()
                    task.wait(12)
                end
            end
        else
            task.wait(1)
        end
    end
end)

