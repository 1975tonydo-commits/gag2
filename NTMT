local function firePlant(position, seedName)
    -- UU TIEN 1: Networking packet
    local packet = findPlantPacket()
    if packet then
        local ok1 = pcall(function() packet:Fire(position, seedName) end)
        if ok1 then return true end
        pcall(function() packet:Fire(seedName, position) end)
        pcall(function() packet:Fire(position) end)
        return true
    end
    -- UU TIEN 2: Raw RemoteEvent/Function
    local rem = findPlantRemote()
    if rem then
        if rem:IsA("RemoteEvent") then
            pcall(function() rem:FireServer(position, seedName) end)
            pcall(function() rem:FireServer(seedName, position) end)
            pcall(function() rem:FireServer(position) end)
        else
            pcall(function() rem:InvokeServer(position, seedName) end)
        end
        return true
    end
    return false
end

