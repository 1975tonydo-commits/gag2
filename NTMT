local function hexColor(hex)
    if Color3.fromHex then
        local ok, c = pcall(Color3.fromHex, hex)
        if ok and c then return c end
    end
    hex = tostring(hex or ""):gsub("#", "")
    if #hex < 6 then return Color3.new(1, 1, 1) end
    return Color3.new(tonumber(hex:sub(1,2),16)/255, tonumber(hex:sub(3,4),16)/255, tonumber(hex:sub(5,6),16)/255)
end

local function universalHttpGet(url)
    local function okBody(b)
        return type(b) == "string" and #b > 100 and not b:find("404", 1, true)
    end
    local ok, body = pcall(function() return game:HttpGet(url) end)
    if ok and okBody(body) then return body end
    local req = getGlobal("request") or getGlobal("http_request")
        or (type(syn) == "table" and syn.request) or (type(http) == "table" and http.request)
    if req then
        ok, body = pcall(req, { Url = url, Method = "GET" })
        if ok and type(body) == "table" then body = body.Body or body.body end
        if okBody(body) then return body end
    end
    return nil
end

local function buildFallbackWindUI()
    local API = { Version = "fallback" }
    function API:Notify(o)
        o = o or {}
        pcall(function()
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = tostring(o.Title or "NTMT HUB"),
                Text = tostring(o.Content or ""),
                Duration = tonumber(o.Duration) or 3,
            })
        end)
    end
    function API.CreateWindow(_, cfg)
        cfg = cfg or {}
        local pg = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui", 20)
        local sg = Instance.new("ScreenGui")
        sg.Name = "NTMTHubUI"
        sg.ResetOnSpawn = false
        sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        sg.Parent = pg
        local open = Instance.new("TextButton")
        open.Size = UDim2.fromOffset(160, 48)
        open.Position = UDim2.new(0, 8, 0.5, -24)
        open.BackgroundColor3 = Color3.fromRGB(46, 200, 80)
        open.TextColor3 = Color3.new(1, 1, 1)
        open.Font = Enum.Font.GothamBold
        open.TextSize = 15
        open.Text = (cfg.OpenButton and cfg.OpenButton.Title) or "Open NTMT HUB"
        open.Parent = sg
        local panel = Instance.new("Frame")
        panel.Size = UDim2.fromOffset(440, 560)
        panel.Position = UDim2.new(0.5, -220, 0.5, -280)
        panel.BackgroundColor3 = Color3.fromRGB(20, 20, 26)
        panel.Visible = false
        panel.Parent = sg
        local scroll = Instance.new("ScrollingFrame")
        scroll.Size = UDim2.new(1, -8, 1, -8)
        scroll.Position = UDim2.new(0, 4, 0, 4)
        scroll.BackgroundTransparency = 1
        scroll.ScrollBarThickness = 6
        scroll.CanvasSize = UDim2.new()
        scroll.Parent = panel
        local layout = Instance.new("UIListLayout")
        layout.Padding = UDim.new(0, 4)
        layout.Parent = scroll
        layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 12)
        end)
        open.MouseButton1Click:Connect(function() panel.Visible = not panel.Visible end)
        local win = {}
        function win.Tag() end
        local function bindEl(obj)
            return {
                SetTitle = function(_, t) if obj then obj.Text = tostring(t) end end,
                SetDesc = function() end,
                Update = function(_, u) if u and u.Title and obj then obj.Text = u.Title end end,
            }
        end
        function win.Tab(_, tc)
            local tab = {}
            local hdr = Instance.new("TextLabel")
            hdr.Size = UDim2.new(1, -8, 0, 28)
            hdr.BackgroundTransparency = 1
            hdr.TextColor3 = Color3.fromRGB(110, 220, 130)
            hdr.Font = Enum.Font.GothamBold
            hdr.TextSize = 15
            hdr.Text = "-- " .. (tc.Title or "Tab") .. " --"
            hdr.Parent = scroll
            function tab.Section(_, s)
                local l = Instance.new("TextLabel")
                l.Size = UDim2.new(1, -8, 0, 22)
                l.BackgroundTransparency = 1
                l.TextColor3 = Color3.fromRGB(160, 160, 160)
                l.Text = s.Title or ""
                l.Parent = scroll
                return bindEl(l)
            end
            function tab.Toggle(_, o)
                local on = o.Default == true
                local b = Instance.new("TextButton")
                b.Size = UDim2.new(1, -8, 0, 32)
                b.Font = Enum.Font.Gotham
                b.TextSize = 13
                b.Parent = scroll
                local function paint()
                    b.Text = (o.Title or "Toggle") .. (on and " [ON]" or " [OFF]")
                    b.BackgroundColor3 = on and Color3.fromRGB(30, 110, 58) or Color3.fromRGB(50, 50, 58)
                    b.TextColor3 = Color3.new(1, 1, 1)
                end
                paint()
                b.MouseButton1Click:Connect(function()
                    on = not on
                    paint()
                    if o.Callback then pcall(o.Callback, on) end
                end)
                local el = bindEl(b)
                function el.SetTitle(_, t) o.Title = t; paint() end
                return el
            end
            function tab.Button(_, o)
                local b = Instance.new("TextButton")
                b.Size = UDim2.new(1, -8, 0, 32)
                b.Text = o.Title or "Button"
                b.BackgroundColor3 = Color3.fromRGB(65, 65, 85)
                b.TextColor3 = Color3.new(1, 1, 1)
                b.Parent = scroll
                b.MouseButton1Click:Connect(function() if o.Callback then pcall(o.Callback) end end)
                return bindEl(b)
            end
            function tab.Slider(_, o)
                local val = (o.Value and o.Value.Default) or 16
                local l = Instance.new("TextLabel")
                l.Size = UDim2.new(1, -8, 0, 32)
                l.BackgroundColor3 = Color3.fromRGB(42, 42, 52)
                l.TextColor3 = Color3.new(1, 1, 1)
                l.Parent = scroll
                local function upd()
                    l.Text = (o.Title or "Slider") .. ": " .. tostring(math.floor(val))
                end
                upd()
                l.MouseButton1Click:Connect(function()
                    val = val + (o.Step or 1)
                    local mx = (o.Value and o.Value.Max) or 250
                    local mn = (o.Value and o.Value.Min) or 16
                    if val > mx then val = mn end
                    upd()
                    if o.Callback then pcall(o.Callback, val) end
                end)
                return bindEl(l)
            end
            function tab.Input(_, o)
                local box = Instance.new("TextBox")
                box.Size = UDim2.new(1, -8, 0, 32)
                box.BackgroundColor3 = Color3.fromRGB(38, 38, 46)
                box.TextColor3 = Color3.new(1, 1, 1)
                box.Text = o.Value or ""
                box.PlaceholderText = o.Placeholder or ""
                box.Parent = scroll
                box.FocusLost:Connect(function(enter)
                    if enter and o.Callback then pcall(o.Callback, box.Text) end
                end)
                return bindEl(box)
            end
            function tab.Paragraph(_, o)
                local l = Instance.new("TextLabel")
                l.Size = UDim2.new(1, -8, 0, 52)
                l.TextWrapped = true
                l.TextXAlignment = Enum.TextXAlignment.Left
                l.TextYAlignment = Enum.TextYAlignment.Top
                l.BackgroundTransparency = 1
                l.TextColor3 = Color3.new(0.92, 0.92, 0.92)
                l.Text = (o.Title or "") .. "\n" .. (o.Desc or "")
                l.Parent = scroll
                local el = bindEl(l)
                function el.SetDesc(_, d) l.Text = (o.Title or "") .. "\n" .. tostring(d or "") end
                return el
            end
            function tab.Dropdown(_, o)
                local idx, vals = 1, o.Values or {}
                local b = Instance.new("TextButton")
                b.Size = UDim2.new(1, -8, 0, 32)
                b.BackgroundColor3 = Color3.fromRGB(52, 52, 68)
                b.TextColor3 = Color3.new(1, 1, 1)
                b.Parent = scroll
                local function paint()
                    b.Text = (o.Title or "Select") .. ": " .. tostring(vals[idx] or "None")
                end
                paint()
                b.MouseButton1Click:Connect(function()
                    if #vals == 0 then return end
                    idx = idx + 1
                    if idx > #vals then idx = 1 end
                    paint()
                    if o.Callback then
                        if o.Multi then pcall(o.Callback, { [vals[idx]] = true })
                        else pcall(o.Callback, vals[idx]) end
                    end
                end)
                return bindEl(b)
            end
            function tab.SetTitle(_, t) hdr.Text = "-- " .. t .. " --" end
            return tab
        end
        return win
    end
    return API
end

