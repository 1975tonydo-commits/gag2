end)
makeButton(ServerTab, "scan_server", "search", function() scanAndFindPet(true) end)
makeButton(ServerTab, "hop_find_pet", "globe", function()
    if petFoundOnServer then
        notify("Find Pet", "Already found on this server", "check", 3)
        return
    end
    if not scanAndFindPet(false) then
        notify("Find Pet", "Hopping to search...", "shuffle", 3)
        hopRandomServer()
    end
end)

