local function matchesCollectKeyword(name)
    name = name:lower()
    for k, enabled in pairs(collectKeywords) do
        if enabled and name:find(k) then return true end
    end
    return false
end

local function collectItem(item)
    local root = item:FindFirstChildWhichIsA("BasePart", true) or (item:IsA("BasePart") and item) or item.PrimaryPart
    local hrp  = getRoot(LocalPlayer)
    if not hrp then return end

    if root and root.Position then
        pcall(function() hrp.CFrame = CFrame.new(root.Position + Vector3.new(0, 5, 0)) end)
        task.wait(0.08)
    end

    local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
    if prompt and fireproximityprompt then
        pcall(fireproximityprompt, prompt, 0)
    end

    local GE = Services.ReplicatedStorage:FindFirstChild("GameEvents")
