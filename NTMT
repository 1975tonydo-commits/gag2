local function getEmptyPlots()
    local plots = {}
    local plot = getCachedOwnedPlot()
    if not plot then return plots end
    local plotsFolder = plot:FindFirstChild("Plots") or plot:FindFirstChild("FarmPlots") or plot
    for _, v in ipairs(plotsFolder:GetDescendants()) do
        if v.Name == "Plot" or v.Name == "FarmPlot" or v:HasTag("Plot") then
            local isEmpty = not v:FindFirstChild("Plant") and not v:GetAttribute("Planted")
            if isEmpty then table.insert(plots, v) end
        end
    end
    return plots
end

