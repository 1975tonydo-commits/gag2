local function getPetNameFromModel(model)
    if not model or not model:IsA("Model") then return nil end
    local nlow = petLowerName(model.Name)
    for _, petName in ipairs(PET_LIST) do
        if nlow:find(petLowerName(petName), 1, true) then
            return petName
        end
    end
    -- Attribute fallback
    local petAttr = model:GetAttribute("PetName") or model:GetAttribute("Species")
    if petAttr then
        for _, petName in ipairs(PET_LIST) do
            if petLowerName(petAttr):find(petLowerName(petName), 1, true) then
