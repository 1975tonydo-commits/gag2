local Services = {
    ReplicatedStorage = cloneref(game:GetService("ReplicatedStorage")),
    Workspace         = cloneref(game:GetService("Workspace")),
    Players           = cloneref(game:GetService("Players")),
    RunService        = cloneref(game:GetService("RunService")),
    VirtualUser       = cloneref(game:GetService("VirtualUser")),
    HttpService       = cloneref(game:GetService("HttpService")),
    TeleportService   = cloneref(game:GetService("TeleportService")),
    CollectionService = cloneref(game:GetService("CollectionService")),
}

local LocalPlayer = Services.Players.LocalPlayer
local Gardens = Services.Workspace:WaitForChild("Gardens", 10)

local Networking, FruitValueCalc, SeedData, GearShopData, PlayerStateClient
local GardenFlags, ExpansionPrices, PetData, PetTypes, PetSizes
local okNet, okSeedData, okGearData, okPlayerState = false, false, false, false

do
    local SharedModules = Services.ReplicatedStorage:WaitForChild("SharedModules", 10)
    if SharedModules then
        okNet, Networking = pcall(require, SharedModules:WaitForChild("Networking", 5))
        if not okNet then Networking = nil end

        local fvc = SharedModules:FindFirstChild("FruitValueCalc")
        if fvc then
            local ok2, mod2 = pcall(require, fvc)
            if ok2 then FruitValueCalc = mod2 end
        end

        local sd = SharedModules:FindFirstChild("SeedData")
        if sd then okSeedData, SeedData = pcall(require, sd) end

        local gsd = SharedModules:FindFirstChild("GearShopData")
        if gsd then okGearData, GearShopData = pcall(require, gsd) end

        local gf = SharedModules:FindFirstChild("Flags") and SharedModules.Flags:FindFirstChild("GardenFlags")
        if gf then pcall(function() GardenFlags = require(gf) end) end
    end

    local SharedData = Services.ReplicatedStorage:FindFirstChild("SharedData")
    if SharedData then
        local ep = SharedData:FindFirstChild("ExpansionPrices")
        if ep then pcall(function() ExpansionPrices = require(ep) end) end
        local pd = SharedData:FindFirstChild("PetData")
        if pd then pcall(function() PetData = require(pd) end) end
        local pt = SharedData:FindFirstChild("PetTypes")
        if pt then pcall(function() PetTypes = require(pt) end) end
        local ps = SharedData:FindFirstChild("PetSizes")
        if ps then pcall(function() PetSizes = require(ps) end) end
    end

    local ClientModules = Services.ReplicatedStorage:FindFirstChild("ClientModules")
    if ClientModules then
        local psc = ClientModules:FindFirstChild("PlayerStateClient")
        if psc then okPlayerState, PlayerStateClient = pcall(require, psc) end
    end
end

local gearReplica = nil
if okPlayerState and PlayerStateClient then
    task.spawn(function()
        pcall(function()
            gearReplica = PlayerStateClient:WaitForLocalReplica(5)
        end)
    end)
end

