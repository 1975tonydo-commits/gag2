    local display = normalizePetName(getPetDisplayName(species, size))
    local speciesNorm = normalizePetName(getPetDisplayName(species, nil))
    if display == targetNorm or speciesNorm == targetNorm then return true end
    return string.find(display, targetNorm, 1, true) ~= nil or string.find(speciesNorm, targetNorm, 1, true) ~= nil
end

