-- Seeds KHONG bao gio mua (special / event / mega / mutation seeds)
-- Match theo substring, lowercase
local SEED_EXCLUDE_PATTERNS = {
    "gold",
    "rainbow",
    "horned melon",
    "mega",
    "poison ivy",
}

local function isSeedExcluded(seedName)
    local low = string.lower(tostring(seedName or ""))
    for _, pat in ipairs(SEED_EXCLUDE_PATTERNS) do
        if string.find(low, pat, 1, true) then return true end
    end
    return false
end

local function norm(value)
    return string.lower(tostring(value or ""):gsub("^%s+", ""):gsub("%s+$", ""))
end

-- Kiem tra item co trong dropdown selection khong
local function whitelistAllows(list, itemName)
    if type(list) ~= "table" then return false end
    local wanted = norm(itemName):gsub("%s+", "")
    for name, enabled in pairs(list) do
        if enabled == true and norm(name):gsub("%s+", "") == wanted then
            return true
        end
    end
    return false
end

