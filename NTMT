    if not okGearData or type(GearShopData) ~= "table" then return nil end
    local candidates = { GearShopData.Data, GearShopData.Gears, GearShopData.Items, GearShopData }
    for _, list in ipairs(candidates) do
        if type(list) == "table" then
            local direct = list[gearName]
            if type(direct) == "table" then
                return tonumber(direct.Cost or direct.Price or direct.Sheckles)
            end
            for _, data in pairs(list) do
                if type(data) == "table" then
                    local name = data.ItemName or data.Name or data.GearName
                    if norm(name) == norm(gearName) then
                        return tonumber(data.Cost or data.Price or data.Sheckles)
                    end
                end
            end
        end
    end
    return nil
end

