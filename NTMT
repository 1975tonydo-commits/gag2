local function isGrown(plant)
    local maxAge = plant:GetAttribute("MaxAge")
    local age = plant:GetAttribute("Age")
    if maxAge == nil or age == nil then return true end
    return age >= maxAge
end

local function getAllPlantsInPlot()
    local out = {}
    local plot = getCachedOwnedPlot()
    if not plot then return out end
    local plantsFolder = plot:FindFirstChild("Plants")
    if not plantsFolder then return out end
    for _, plant in ipairs(plantsFolder:GetChildren()) do
        local fruitsFolder = plant:FindFirstChild("Fruits")
        if fruitsFolder then
            for _, fruit in ipairs(fruitsFolder:GetChildren()) do
                if fruit:IsA("Model") and fruit:GetAttribute("PlantId") then
                    if not harvestRipeOnly or isGrown(fruit) then
                        table.insert(out, fruit)
                    end
                end
            end
        elseif plant:IsA("Model") and plant:GetAttribute("PlantId") then
            if not harvestRipeOnly or isGrown(plant) then
                table.insert(out, plant)
            end
        end
    end
    return out
end

