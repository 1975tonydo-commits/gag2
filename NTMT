local function matchesPetTarget(species, size, targetName)
    if type(species) ~= "string" or species == "" then return false end
    if type(targetName) ~= "string" or targetName == "" then return false end
    local targetNorm = normalizePetName(targetName)
    local display = normalizePetName(getPetDisplayName(species, size))
    local speciesNorm = normalizePetName(species)
    local speciesDisplay = normalizePetName(getPetDisplayName(species, nil))
    if display == targetNorm or speciesNorm == targetNorm or speciesDisplay == targetNorm then
        return true
    end
    return false
end

