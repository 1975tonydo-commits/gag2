-- CONFIRMED logic GAG2: Networking.NPCS.SellAll:Fire()
local SELL_REMOTE_NAMES = {
    "Sell_Inventory", "SellInventory", "Sell_All", "SellAll", "SellItems",
}
local SELL_NETWORKING_PATHS = {
    { "NPCS", "SellAll" }, { "NPCS", "Sell" }, { "NPCs", "SellAll" }, { "NPCs", "Sell" },
    { "Sell", "Sell" }, { "Sell", "SellAll" }, { "Sell", "SellInventory" },
    { "Garden", "Sell" }, { "Garden", "SellAll" }, { "Garden", "SellInventory" },
    { "Inventory", "Sell" }, { "Inventory", "SellAll" },
}

local cachedSellRemotes  = {}
local cachedSellNetworks = {}
local cachedSellCFrame   = nil

local function rebuildSellCache()
    table.clear(cachedSellRemotes)
    table.clear(cachedSellNetworks)
    local GE = Services.ReplicatedStorage:FindFirstChild("GameEvents")
    if GE then
        for _, name in ipairs(SELL_REMOTE_NAMES) do
            local rem = GE:FindFirstChild(name)
            if rem and (rem:IsA("RemoteEvent") or rem:IsA("RemoteFunction")) then
                table.insert(cachedSellRemotes, rem)
            end
        end
    end
    for _, obj in ipairs(Services.ReplicatedStorage:GetDescendants()) do
        if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
            for _, name in ipairs(SELL_REMOTE_NAMES) do
                if obj.Name == name and not table.find(cachedSellRemotes, obj) then
                    table.insert(cachedSellRemotes, obj)
                    break
                end
            end
        end
    end
    if Networking then
        for _, path in ipairs(SELL_NETWORKING_PATHS) do
            local cat = Networking[path[1]]
            local fn  = cat and cat[path[2]]
            if fn and type(fn) == "table" and fn.Fire then
                table.insert(cachedSellNetworks, fn)
            end
        end
    end
end
rebuildSellCache()

local function findSellStandCFrame()
    if cachedSellCFrame then return cachedSellCFrame end
    for _, obj in ipairs(Services.Workspace:GetDescendants()) do
        local name = obj.Name:lower()
        if (name:find("sell") and (obj:IsA("BasePart") or obj:IsA("Model"))) then
            local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt", true)
            if prompt then
                local part = getPartFromObj(obj) or (prompt.Parent and prompt.Parent:IsA("BasePart") and prompt.Parent)
                if part then
                    cachedSellCFrame = part.CFrame + Vector3.new(0, 3, 0)
                    return cachedSellCFrame
                end
            end
        end
    end
    return nil
end

-- ============ SELL BYPASS ============
-- 1. Rate limit (server thuong co cooldown ~1s cho sell)
-- 2. Random jitter de fire khong dung pattern 0.1s/lan
-- 3. Chi fire 1 remote duy nhat thay vi spam tat ca
local lastSellFire = 0
local sellMinInterval = 0.5  -- toi thieu 0.5s/lan sell (giong nguoi choi)

local function fireSellRemotes()
    local now = os.clock()
    if now - lastSellFire < sellMinInterval then
        return false
    end
    lastSellFire = now + (math.random() * 0.15)  -- jitter

    -- Uu tien Networking (cleaner, ko bi flag)
    if #cachedSellNetworks > 0 then
        pcall(function() cachedSellNetworks[1]:Fire() end)
        return true
    end
    -- Fallback raw remote
    if #cachedSellRemotes > 0 then
        local rem = cachedSellRemotes[1]
        pcall(function()
            if rem:IsA("RemoteEvent") then rem:FireServer() else rem:InvokeServer() end
        end)
        return true
    end
    return false
end

local function sellInventory()
    if sellInfRange then
        local hrp = getRoot(LocalPlayer)
        local origCF = hrp and hrp.CFrame
        local sellCF = findSellStandCFrame()
        if hrp and sellCF then
            pcall(function() hrp.CFrame = sellCF end)
            task.wait(0.08)
            fireSellRemotes()
            task.wait(0.08)
            for _, obj in ipairs(Services.Workspace:GetDescendants()) do
                if obj:IsA("ProximityPrompt") and obj.Name:lower():find("sell") then
                    pcall(fireproximityprompt, obj, 0)
                end
            end
            task.wait(0.08)
            if origCF then pcall(function() hrp.CFrame = origCF end) end
            return true
        end
    end
    fireSellRemotes()
    return true
end

