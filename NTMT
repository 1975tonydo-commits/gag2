local function buySeed(name, amount)
    amount = amount or buyAmount
    pcall(function()
        -- Cách 1: GameEvents trực tiếp
        local GE = Services.ReplicatedStorage:FindFirstChild("GameEvents")
        if GE then
            local rem = GE:FindFirstChild("Buy_Seed") or GE:FindFirstChild("PurchaseSeed") or GE:FindFirstChild("ShopBuy")
            if rem then
                if rem:IsA("RemoteEvent") then rem:FireServer(name, amount)
                else rem:InvokeServer(name, amount) end
                return
            end
        end
        
        -- Cách 2: Networking module (chính xác nhất)
        if Networking then
            local shop = Networking.Shop or Networking.Garden or Networking
            if shop.BuySeed then shop.BuySeed:Fire(name, amount)
            elseif shop.Buy_Seed then shop.Buy_Seed:Fire(name, amount)
            elseif shop.PurchaseSeed then shop.PurchaseSeed:Fire(name, amount) end
        end
    end)
end

local function buyGear(name, amount)
