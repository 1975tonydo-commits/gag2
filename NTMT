    for _, entry in ipairs(UIRegistry) do
        local el, key, kind = entry.el, entry.key, entry.kind
        if el and el.Parent then
            pcall(function()
                if kind == "title" and el.SetTitle then
                    el:SetTitle(tr(key))
                elseif kind == "desc" and el.SetDesc then
                    el:SetDesc(tr(key))
                elseif kind == "tab" and el.SetTitle then
                    el:SetTitle(tr(key))
                end
            end)
        end
    end
end

