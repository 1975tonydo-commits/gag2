local harvestRipeOnly = true
local function isGrown(plant)
    local maxAge = plant:GetAttribute("MaxAge")
    local age    = plant:GetAttribute("Age")
    if maxAge == nil or age == nil then return true end
    return age >= maxAge
end

local function getAllPlantsInPlot()
    local out = {}
    local plot = getCachedOwnedPlot()
    if not plot then return out end
    local plantsFolder = plot:FindFirstChild("Plants")
    if not plantsFolder then return out end

    for _, plant in ipairs(plantsFolder:GetChildren()) do
        local fruitsFolder = plant:FindFirstChild("Fruits")
        if fruitsFolder then
            for _, fruit in ipairs(fruitsFolder:GetChildren()) do
                if fruit:IsA("Model") and fruit:GetAttribute("PlantId") then
                    if not harvestRipeOnly or isGrown(fruit) then
                        table.insert(out, fruit)
                    end
                end
            end
        elseif plant:IsA("Model") and plant:GetAttribute("PlantId") then
            if not harvestRipeOnly or isGrown(plant) then
                table.insert(out, plant)
            end
        end
    end
    return out
end

local getHarvestablePlants = getAllPlantsInPlot

local function getPartFromObj(obj)
    if not obj then return nil end
    if obj:IsA("BasePart") then return obj end
    if obj:IsA("Model") then
        return obj.PrimaryPart
            or obj:FindFirstChild("HarvestPart")
            or obj:FindFirstChildWhichIsA("BasePart", true)
    end
    return obj:FindFirstChildWhichIsA("BasePart", true)
end

-- ============ HARVEST BYPASS ============
-- 1. Validate plant truoc khi fire (anti invalid-data detection)
-- 2. Verify ownership (plant phai trong plot cua minh)
-- 3. Rate limit + random jitter (anti rate-limit detection)
local lastHarvestFire = 0
local harvestMinInterval = 0.015  -- 15ms toi thieu giua 2 lan fire (~66/s)

local function harvestPlant(plant)
    if not plant or not plant.Parent or not Networking then return false end
    local id = plant:GetAttribute("PlantId")
    if not id then return false end
    local fruitid = plant:GetAttribute("FruitId") or ""

    -- Rate limit voi jitter ngau nhien (anti pattern detection)
    local now = os.clock()
    local elapsed = now - lastHarvestFire
    if elapsed < harvestMinInterval then
        task.wait(harvestMinInterval - elapsed + math.random() * 0.01)
    end
    lastHarvestFire = os.clock()

    -- Verify plant van trong plot cua minh truoc khi fire
    -- (tranh server reject vi plant da bi harvest hoac di chuyen)
    local myPlot = getCachedOwnedPlot()
    if myPlot and not plant:IsDescendantOf(myPlot) then
        return false
    end

    local ok = pcall(function()
        Networking.Garden.CollectFruit:Fire(id, fruitid)
    end)
    return ok
end

local function harvestPlantInfRange(plant, returnCFrame)
    local hrp = getRoot(LocalPlayer)
    if not hrp then return harvestPlant(plant) end
    local part = getPartFromObj(plant)
    if part then
        pcall(function() hrp.CFrame = part.CFrame + Vector3.new(0, 3, 0) end)
        task.wait()
    end
    local ok = harvestPlant(plant)
    if returnCFrame then
        pcall(function() hrp.CFrame = returnCFrame end)
    end
    return ok
end

