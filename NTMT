-- Check if a player is inside our garden boundary
local function isInMyGarden(player)
    if player == LocalPlayer then return false end
    local char = player.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local myPlot = getCachedOwnedPlot()
    if not myPlot then return false end
    -- Use bounding box of the plot
    local ok, cf, size = pcall(function() return myPlot:GetBoundingBox() end)
    if not ok then return false end
    local diff = hrp.Position - cf.Position
    return math.abs(diff.X) <= (size.X / 2 + 5)
       and math.abs(diff.Z) <= (size.Z / 2 + 5)
end

-- Equip shovel from backpack
local function equipShovel()
    local bp = LocalPlayer:FindFirstChild("Backpack")
    if not bp then return false end
    for _, tool in ipairs(bp:GetChildren()) do
        if tool:IsA("Tool") and tool.Name:lower():find("shovel") then
            local hum = getHumanoid(LocalPlayer)
            if hum then
                hum:EquipTool(tool)
                return true
            end
        end
    end
    return false
end

-- Hit stealer using tool activation
local function hitStealer(target)
    local char = LocalPlayer.Character
    if not char then return end
    local tool = char:FindFirstChildOfClass("Tool")
    if not tool then return end
    -- TP close to target then activate
    local tRoot = getRoot(target)
    local myRoot = getRoot(LocalPlayer)
    if tRoot and myRoot then
        pcall(function()
            myRoot.CFrame = tRoot.CFrame + Vector3.new(0, 1, 2)
        end)
        task.wait(0.1)
    end
    -- Try all tool activation methods
    pcall(function() tool:Activate() end)
    local GE = Services.ReplicatedStorage:FindFirstChild("GameEvents")
    if GE then
        for _, rem in ipairs(GE:GetChildren()) do
            local n = rem.Name:lower()
            if n:find("hit") or n:find("attack") or n:find("shovel") then
                if rem:IsA("RemoteEvent") then
                    pcall(function() rem:FireServer(target.Character) end)
                end
            end
        end
    end
end

