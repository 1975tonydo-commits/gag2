-- POST tien ich (multi-executor)
local function universalHttpPost(url, jsonBody)
    local req = (syn and syn.request) or (http and http.request) or http_request or request or (fluxus and fluxus.request)
    if req then
        local res = req({
            Url = url,
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = jsonBody,
        })
        return res and (res.StatusCode or res.Status or 0)
    end
    -- Fallback HttpService (chi work neu HttpService dat ban quyen)
    local HS = game:GetService("HttpService")
    local ok = pcall(function()
        HS:PostAsync(url, jsonBody, Enum.HttpContentType.ApplicationJson)
    end)
    return ok and 200 or 0
end

-- JSON encode (HttpService)
local HttpService = game:GetService("HttpService")
local function jsonEncode(t)
    local ok, s = pcall(function() return HttpService:JSONEncode(t) end)
    return ok and s or "{}"
end

