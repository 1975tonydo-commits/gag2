local plantSpotIndex = 0
local function getNextPlantPosition()
    if #savedPlantPositions == 0 then cachePlantPositions() end
    if #savedPlantPositions == 0 then return nil end
    plantSpotIndex = (plantSpotIndex % #savedPlantPositions) + 1
    return savedPlantPositions[plantSpotIndex]
