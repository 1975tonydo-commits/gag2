    pcall(function()
        local GE = Services.ReplicatedStorage:FindFirstChild("GameEvents")
        if GE then
            local rem = GE:FindFirstChild("Buy_Gear") or GE:FindFirstChild("PurchaseGear")
            if rem then
                if rem:IsA("RemoteEvent") then rem:FireServer(name, amount)
                else rem:InvokeServer(name, amount) end
                return
            end
        end
        if Networking then
            local shop = Networking.Shop or Networking.Garden or Networking
            if shop.BuyGear then shop.BuyGear:Fire(name, amount)
            elseif shop.Buy_Gear then shop.Buy_Gear:Fire(name, amount) end
        end
    end)
end

