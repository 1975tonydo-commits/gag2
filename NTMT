local savedPlantPositions = {}

local function cachePlantPositions()
    table.clear(savedPlantPositions)
    local plot = getCachedOwnedPlot()
    if not plot then return end
    local visual = plot:FindFirstChild("Visual")
    if not visual then return end
    for _, col in ipairs(visual:GetChildren()) do
        if col.Name:match("^PlantAreaColumn") then
            for _, part in ipairs(col:GetChildren()) do
                if part:IsA("BasePart") then
                    table.insert(savedPlantPositions, part.Position)
                end
            end
        end
    end
end
