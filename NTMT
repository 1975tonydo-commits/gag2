    }
    for _, path in ipairs(candidatePaths) do
        local cat = Networking[path[1]]
        local fn  = cat and cat[path[2]]
        if type(fn) == "table" and fn.Fire then
            cachedPlantPacket = fn
            cachedPlantPacketName = ("Networking.%s.%s"):format(path[1], path[2])
            return fn
        end
    end
    -- Scan tat ca category cua Networking
    for catName, cat in pairs(Networking) do
        if type(cat) == "table" then
            for fnName, fn in pairs(cat) do
                local fl = string.lower(tostring(fnName))
                if type(fn) == "table" and fn.Fire and fl:find("plant") then
                    cachedPlantPacket = fn
                    cachedPlantPacketName = ("Networking.%s.%s"):format(catName, fnName)
                    return fn
                end
            end
        end
    end
    return nil
end

local function findPlantRemote()
    if cachedPlantRemote and cachedPlantRemote.Parent then return cachedPlantRemote end
    local GE = Services.ReplicatedStorage:FindFirstChild("GameEvents")
    if GE then
        for _, n in ipairs(PLANT_REMOTE_NAMES) do
            local r = GE:FindFirstChild(n)
            if r and (r:IsA("RemoteEvent") or r:IsA("RemoteFunction")) then
                cachedPlantRemote = r
                return r
            end
        end
    end
    for _, obj in ipairs(Services.ReplicatedStorage:GetDescendants()) do
        if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
            local n = obj.Name:lower()
            if n:find("plant") and not n:find("plantid") and not n:find("complete") then
                cachedPlantRemote = obj
                return obj
            end
        end
    end
    return nil
end

