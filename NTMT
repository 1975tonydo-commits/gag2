local function hookShopRestockWatchers()
    local stockRoot = Services.ReplicatedStorage:FindFirstChild("StockValues")
    if not stockRoot then return end
    local function watchRestock(shopFolder)
        if not shopFolder then return end
        local last = shopFolder:FindFirstChild("UnixLastRestock")
        if last and last:IsA("ValueBase") then
            last.Changed:Connect(function()
                task.defer(refreshShopStockUI)
            end)
        end
        local items = shopFolder:FindFirstChild("Items")
        if items then
            items.ChildAdded:Connect(function(ch)
                task.defer(refreshShopStockUI)
                if ch:IsA("ValueBase") then
                    ch.Changed:Connect(function() task.defer(refreshShopStockUI) end)
                end
            end)
            for _, child in ipairs(items:GetChildren()) do
                if child:IsA("ValueBase") then
                    child.Changed:Connect(function() task.defer(refreshShopStockUI) end)
                end
            end
        end
    end
    watchRestock(stockRoot:FindFirstChild("SeedShop"))
    watchRestock(stockRoot:FindFirstChild("GearShop"))
end

