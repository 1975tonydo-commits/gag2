local WEATHER_NAMES = {
    "Rain", "Lightning", "Rainbow", "Snowfall", "Starfall", "Aurora Borealis",
    "Blood Moon", "Midas Moon", "Rainbow Moon", "Blizzard", "Aurora",
}

local function findActiveWeather()
    -- Check 1: ReplicatedStorage.Weather/ActiveWeather (StringValue)
    local RS = Services.ReplicatedStorage
    for _, name in ipairs({ "ActiveWeather", "Weather", "CurrentWeather", "WeatherType", "WeatherEvent" }) do
        local obj = RS:FindFirstChild(name)
        if obj then
            if obj:IsA("StringValue") and obj.Value and #obj.Value > 0 then return obj.Value end
            if obj:IsA("Folder") or obj:IsA("Configuration") then
                for _, c in ipairs(obj:GetChildren()) do
                    if (c:IsA("BoolValue") and c.Value) or (c:IsA("StringValue") and #c.Value > 0) then
                        return c.Name
                    end
                end
            end
        end
    end
    -- Check 2: Workspace.WeatherEvents/Effects con
    local WS = Services.Workspace
    for _, name in ipairs({ "WeatherEvents", "Weather", "ActiveWeather", "WeatherEffects" }) do
        local obj = WS:FindFirstChild(name)
        if obj then
            for _, c in ipairs(obj:GetChildren()) do
                for _, wn in ipairs(WEATHER_NAMES) do
                    if c.Name:lower():find(wn:lower(), 1, true) then return wn end
                end
            end
        end
    end
    -- Check 3: Night
    local night = RS:FindFirstChild("Night")
    if night and night.Value then return "Night" end
    return "Day"
end

-- Lay end time (epoch hoac so giay con lai)
local function findWeatherEndTime()
    local RS = Services.ReplicatedStorage
    for _, name in ipairs({ "WeatherEndTime", "WeatherEnd", "EndTime", "WeatherUnixEnd" }) do
        local v = RS:FindFirstChild(name)
        if v and v.Value then
            local n = tonumber(v.Value)
            if n then
                if n > os.time() then
                    -- epoch
                    return os.date("%H:%M:%S", n)
                else
                    -- so giay con lai
                    return ("~%ds"):format(math.floor(n))
                end
            end
        end
    end
    return "N/A"
end

