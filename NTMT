            end
        end
    end
    -- Quét toàn bộ ReplicatedStorage
    for _, obj in ipairs(Services.ReplicatedStorage:GetDescendants()) do
        if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
            local n = obj.Name:lower()
            if n:find("plant") and not n:find("plantid") then
                cachedPlantRemote = obj
                return obj
            end
        end
    end
    return nil
end

local function getEquippedSeedName()
    local char = LocalPlayer.Character
    if not char then return nil end
    local tool = char:FindFirstChildOfClass("Tool")
    if not tool then return nil end
    -- Roblox tool name thường là "Carrot Seed" hoặc "Carrot"
    local n = tool.Name
    n = n:gsub(" Seed", ""):gsub("Seed", "")
    return n:match("^%s*(.-)%s*$"), tool
end

local function firePlant(position, seedName)
    local rem = findPlantRemote()
    if rem then
        if rem:IsA("RemoteEvent") then
            pcall(function() rem:FireServer(position, seedName) end)
            pcall(function() rem:FireServer(seedName, position) end)
            pcall(function() rem:FireServer(position) end)
        else
            pcall(function() rem:InvokeServer(position, seedName) end)
        end
        return true
    end
    if Networking then
        for _, path in ipairs({ {"Garden","Plant"}, {"Garden","PlantSeed"}, {"Plant","Plant"} }) do
            local fn = (Networking[path[1]] or {})[path[2]]
            if fn and fn.Fire then
                pcall(function() fn:Fire(position, seedName) end)
                return true
            end
        end
    end
    return false
end

