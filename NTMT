local function whitelistAllows(list, itemName)
    if type(list) ~= "table" then return false end
    if list.All == true then return true end
    local wanted = norm(itemName):gsub("%s+", "")
    for name, enabled in pairs(list) do
        if name ~= "All" and enabled == true and norm(name):gsub("%s+", "") == wanted then
            return true
        end
    end
    return false
end

local function safePacket(packet, ...)
    if not packet then return nil end
    local ok, result = pcall(function(...) return packet:Fire(...) end, ...)
    if not ok then return nil end
    return result
end

local function safeFire(packet, ...)
    if not packet then return false end
    return pcall(function(...) packet:Fire(...) end, ...) == true
end

