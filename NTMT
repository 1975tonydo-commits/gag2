local sellInterval = 0.1

local cachedSellRemotes  = {}
local cachedSellNetworks = {}

local function rebuildSellCache()
    table.clear(cachedSellRemotes)
    table.clear(cachedSellNetworks)

    for _, obj in ipairs(Services.ReplicatedStorage:GetDescendants()) do
        if (obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction")) and obj.Name:lower():find("sell") then
            table.insert(cachedSellRemotes, obj)
        end
    end

    if Networking then
        local function walk(tbl, depth)
            if depth > 4 or type(tbl) ~= "table" then return end
            for k, v in pairs(tbl) do
                if type(k) == "string" and k:lower():find("sell") and type(v) == "table" and v.Fire then
                    table.insert(cachedSellNetworks, v)
                end
                if type(v) == "table" and v ~= tbl then
                    pcall(walk, v, depth + 1)
                end
            end
        end
        pcall(walk, Networking, 1)
    end
end

rebuildSellCache()

Services.ReplicatedStorage.DescendantAdded:Connect(function(d)
    if (d:IsA("RemoteEvent") or d:IsA("RemoteFunction")) and d.Name:lower():find("sell") then
        table.insert(cachedSellRemotes, d)
    end
end)

local function sellInventory()
    for _, rem in ipairs(cachedSellRemotes) do
        pcall(function()
            if rem:IsA("RemoteEvent") then rem:FireServer() else rem:InvokeServer() end
        end)
    end
    for _, fn in ipairs(cachedSellNetworks) do
        pcall(function() fn:Fire() end)
    end
    return true
end

