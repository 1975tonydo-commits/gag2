    if v then return v end
    local ls = LocalPlayer:FindFirstChild("leaderstats")
    if ls then
        for _, n in ipairs({ "Sheckles", "sheckles", "Money", "Cash", "Coins" }) do
            local s = ls:FindFirstChild(n)
