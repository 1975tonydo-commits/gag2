local function collectWildPetModels()
    local out, seen = {}, {}
    local spawns = getWildPetSpawns()
    if spawns then
        for _, model in ipairs(spawns:GetChildren()) do
            if model:IsA("Model") and not seen[model] then
                seen[model] = true
                table.insert(out, model)
            end
        end
    end
    local map = Services.Workspace:FindFirstChild("Map")
    if map then
        for _, obj in ipairs(map:GetDescendants()) do
            if obj:IsA("Model") and obj.Name:find("^WildPet") and not seen[obj] then
                seen[obj] = true
                table.insert(out, obj)
            end
        end
    end
    return out
end

local function scanWildPetsForTarget(targetName, forTame)
    local candidates = {}
    for _, model in ipairs(collectWildPetModels()) do
        local species = model:GetAttribute("PetName")
        local size = model:GetAttribute("PetSize")
        if matchesPetTarget(species, size, targetName) then
            local ref = resolveRefPartFromModel(model)
            if forTame then
                if ref and isRefTameable(ref) then
                    table.insert(candidates, { ref = ref, model = model, price = ref:GetAttribute("Price") or 0 })
                end
            else
                return { ref = ref, model = model, price = ref and ref:GetAttribute("Price") or 0 }
            end
        end
    end
    if forTame and #candidates > 0 then
        table.sort(candidates, function(a, b) return a.price < b.price end)
        return candidates[1]
    end
    return nil
end

local function deepScanServerForPet(targetName, passes, forTame)
