        table.concat(gearLines, "\n"),
        "",
        "** pets **",
        table.concat(petLines, "\n"),
        "",
        "** inventory **",
        table.concat(invLines, "\n"),
        "",
        ("** sheckles amount: %s **"):format(tostring(sheckles)),
    }, "\n")

    return {
        username = "NTMT HUB",
        embeds = {
            {
                title = "NTMT HUB | Grow a Garden 2",
                description = desc,
                color = 5763719,
                footer = { text = ("Total inv: %d items"):format(invTotal) },
                timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
            },
        },
    }
end

local function sendWebhook(reason)
    if not webhookUrl or webhookUrl == "" or not webhookUrl:lower():find("discord") then
        WindUI:Notify({ Title = "Webhook", Content = "URL webhook khong hop le", Icon = "circle-x", Duration = 3 })
        return false
