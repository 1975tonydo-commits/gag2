local function isRainbowGoldSeed(item)
    if not item or not item.Parent then return false end
    -- Check attribute truoc (chuan tu game)
    if item:GetAttribute("RainbowSeed") == true or item:GetAttribute("GoldSeed") == true then
        return item:FindFirstChildWhichIsA("ProximityPrompt", true) ~= nil
    end
    -- Fallback theo ten
    local n = item.Name:lower()
    if n:find("rainbow") or n:find("gold") then
        return item:FindFirstChildWhichIsA("ProximityPrompt", true) ~= nil
    end
    return false
