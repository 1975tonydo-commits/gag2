        task.wait(collectInterval)
        if genv.ftgs_AutoCollectRainbowGold or genv.ftgs_AutoCollectItemDrop then
            pcall(function()
                -- Uu tien quet SeedPackSpawns truoc (chinh xac va nhanh hon)
                if genv.ftgs_AutoCollectRainbowGold then
                    local folder = getSeedPackFolder()
                    if folder then
                        for _, spawn in ipairs(folder:GetChildren()) do
                            if not genv.ftgs_AutoCollectRainbowGold then break end
                            local isR = spawn:GetAttribute("RainbowSeed") == true
                            local isG = spawn:GetAttribute("GoldSeed") == true
                            if isR or isG then
                                local prompt = spawn:FindFirstChildWhichIsA("ProximityPrompt", true)
                                if prompt then
                                    fireCollect(spawn)
                                end
                            end
                        end
                    end
                end
                -- Quet workspace cho item drop (cham hon vi descendants)
                if genv.ftgs_AutoCollectItemDrop then
                    for _, item in ipairs(Services.Workspace:GetDescendants()) do
                        if not genv.ftgs_AutoCollectItemDrop then break end
                        if isItemDrop(item) then fireCollect(item) end
                    end
                end
            end)
        end
    end
end)

-- Anti-Steal Shovel loop (scan 24/7 khi bat)
task.spawn(function()
    while true do
        if genv.ftgs_AntiSteal then
            pcall(function()
                local stealers = findStealersInPlot()
                if #stealers > 0 then
                    local myRoot = getRoot(LocalPlayer)
                    local origCF = myRoot and myRoot.CFrame
                    for _, p in ipairs(stealers) do
                        if not genv.ftgs_AntiSteal then break end
                        attackPlayer(p)
                    end
                    if origCF and myRoot then
                        task.wait(0.05)
                        pcall(function() myRoot.CFrame = origCF end)
                    end
                end
            end)
            task.wait(0.05)
        else
            task.wait(0.25)
        end
    end
end)

