            pcall(function() Networking.Garden.RequestGardens:Fire() end)
        end
    end)
end

task.spawn(function()
    local deadline = os.clock() + 120
    while os.clock() < deadline do
        if CollectionService:HasTag(LocalPlayer, "DataLoaded") then break end
        if LocalPlayer:GetAttribute("PlotId") then break end
        task.wait(0.5)
    end
    cachePlantAreas()
    local refreshedSeeds = buildSeedNameList()
    for _, name in ipairs(refreshedSeeds) do
        if not table.find(SEED_NAMES, name) then table.insert(SEED_NAMES, name) end
    end
    table.sort(SEED_NAMES)
    plantAllOrder = cloneList(SEED_NAMES)
end)

