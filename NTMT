-- WildPet_<X>_<refName> => ref part trong WildPetRef
local function resolveRefPartFromModel(model)
    if not model or not model:IsA("Model") then return nil end
    local folder = getWildPetFolder()
    if folder then
        local refName = string.match(model.Name, "^WildPet_.-_(.+)$")
        if refName then
            local ref = folder:FindFirstChild(refName)
            if ref and ref:IsA("BasePart") then return ref end
        end
        for _, child in ipairs(folder:GetChildren()) do
            if child:IsA("BasePart") and child:GetAttribute("PetName") == model:GetAttribute("PetName") then
                return child
            end
        end
    end
    for _, d in ipairs(model:GetDescendants()) do
        if d:IsA("BasePart") and (d:GetAttribute("Price") or d:FindFirstChildWhichIsA("ProximityPrompt")) then
            return d
        end
    end
    return getModelRoot(model)
end

local function isRefTameable(refPart)
    if not refPart or not refPart:IsA("BasePart") or not refPart.Parent then return false end
    local ownerId = refPart:GetAttribute("OwnerUserId")
    if ownerId == LocalPlayer.UserId then return false end
    if type(ownerId) == "number" and ownerId ~= 0 then return false end
    local price = refPart:GetAttribute("Price")
    if type(price) == "number" and getSheckles() < price then return false end
    return true
end

local function matchesPetName(species, target)
    if not species or not target then return false end
    local a = string.lower(tostring(species)):gsub("%s+", "")
    local b = string.lower(tostring(target)):gsub("%s+", "")
    return a == b or a:find(b, 1, true) ~= nil or b:find(a, 1, true) ~= nil
end

local function getModelRoot(model)
    return model.PrimaryPart or model:FindFirstChild("RootPart") or model:FindFirstChildWhichIsA("BasePart")
end

local function catchWildPet(model, ref)
    if not model or not ref then return false end
    if not Networking or not Networking.Pets or not Networking.Pets.WildPetTame then return false end
    local hrp = getRoot(LocalPlayer)
    if not hrp then return false end

    local key = tostring(ref)
    local now = os.clock()
    if petCatchCooldown[key] and now - petCatchCooldown[key] < 8 then
        return false
    end
    petCatchCooldown[key] = now

    local savedCF = hrp.CFrame
    local root = getModelRoot(model)
    if root then
        pcall(function() hrp.CFrame = CFrame.new(root.Position + Vector3.new(0, 3, 0)) end)
    end
    task.wait(0.2)

    local tameDone = false
    local conn
    if Networking.Pets.WildPetTameResult and Networking.Pets.WildPetTameResult.OnClientEvent then
        conn = Networking.Pets.WildPetTameResult.OnClientEvent:Connect(function(_, userId)
            if userId == LocalPlayer.UserId then tameDone = true end
        end)
    end

    pcall(function() Networking.Pets.WildPetTame:Fire(ref) end)

    local deadline = os.clock() + 2.5
    while not tameDone and os.clock() < deadline do task.wait(0.08) end
    if conn then conn:Disconnect() end

    pcall(function() hrp.CFrame = savedCF end)

    if tameDone then
        local petName = model:GetAttribute("PetName") or model.Name
        BoughtPets[petName] = (BoughtPets[petName] or 0) + 1
        return true
    end
    return false
end

local function collectWildPetModels()
    local out = {}
    local seen = {}
    local spawns = getWildPetSpawns()
    if spawns then
        for _, model in ipairs(spawns:GetChildren()) do
            if model:IsA("Model") and not seen[model] then
                seen[model] = true
                table.insert(out, model)
            end
        end
    end
    local map = Services.Workspace:FindFirstChild("Map")
    if map then
        for _, obj in ipairs(map:GetDescendants()) do
            if obj:IsA("Model") and obj.Name:find("^WildPet") and not seen[obj] then
                seen[obj] = true
                table.insert(out, obj)
            end
        end
    end
    return out
end

