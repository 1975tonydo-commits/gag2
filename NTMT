local function getGlobal(n)
    local v = rawget(_G, n)
    if v ~= nil then return v end
    if type(getgenv) == "function" then
        local ok, e = pcall(getgenv)
        if ok and type(e) == "table" then
            v = rawget(e, n)
            if v ~= nil then return v end
        end
    end
    if type(getrenv) == "function" then
        local ok, e = pcall(getrenv)
        if ok and type(e) == "table" then
            v = rawget(e, n)
            if v ~= nil then return v end
        end
    end
    return nil
end

