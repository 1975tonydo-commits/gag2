local function loadModelUniversal(assetId)
    local methods = {
        function()
            local fn = (game.GetObjects and function() return game:GetObjects("rbxassetid://"..assetId) end)
                    or (getobjects and function() return getobjects("rbxassetid://"..assetId) end)
                    or (getcustomasset and nil)
            if fn then
                local objs = fn()
                if objs and objs[1] then return objs[1] end
            end
        end,
        function()
            return Services.InsertService:LoadAsset(tonumber(assetId))
        end,
        function()
            if not (hasFs and getcustomasset) then return nil end
            local url = "https://assetdelivery.roblox.com/v1/asset/?id=" .. assetId
            local data = universalHttpGet(url)
            if not data then return nil end
            local path = "ftgshub_model_" .. assetId .. ".rbxm"
            writefile(path, data)
            local asset = getcustomasset(path)
            local ok, m = pcall(function()
                return game:GetObjects(asset)[1]
            end)
            if ok then return m end
        end,
    }

    for i, m in ipairs(methods) do
        local ok, result = pcall(m)
        if ok and result then
            return result, i
        end
    end
    return nil
end

ModelsTab:Button({
    Title = "Load Model",
    Desc  = "Spawn model vào Workspace",
    Icon  = "download",
    Callback = function()
        local id = currentAssetId:match("%d+")
        if not id then
            WindUI:Notify({ Title = "Lỗi", Content = "Asset ID không hợp lệ", Icon = "circle-x", Duration = 3 })
            return
        end

        WindUI:Notify({ Title = "Đang tải", Content = "Asset ID: " .. id, Icon = "loader", Duration = 2 })

        local model, methodUsed = loadModelUniversal(id)
        if not model then
            WindUI:Notify({
                Title = "Thất bại",
                Content = "Không tải được model. Executor có thể không hỗ trợ.",
                Icon = "circle-x",
                Duration = 4,
            })
            return
        end

        local spawnCFrame = CFrame.new(0, 50, 0)
        if spawnAtPlayer then
            local lp = Services.Players.LocalPlayer
            local char = lp and lp.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then
                spawnCFrame = hrp.CFrame * CFrame.new(0, 0, -10)
            end
        end

        if model:IsA("Model") then
            model:PivotTo(spawnCFrame)
        elseif model:IsA("BasePart") then
            model.CFrame = spawnCFrame
        end

        model.Name = "LoadedModel_" .. id
        model.Parent = Services.Workspace

        WindUI:Notify({
            Title = "Thành công",
            Content = ("Đã spawn model (method #%d)"):format(methodUsed),
            Icon = "circle-check",
            Duration = 3,
        })
    end
})

ModelsTab:Button({
