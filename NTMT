-- Show what remotes exist (giúp debug)
local function listRemoteNames()
    local GE = Services.ReplicatedStorage:FindFirstChild("GameEvents")
    if not GE then return "Không có ReplicatedStorage.GameEvents" end
    local list = {}
    for _, c in ipairs(GE:GetChildren()) do
        table.insert(list, c.Name .. " (" .. c.ClassName .. ")")
    end
    table.sort(list)
    return #list > 0 and table.concat(list, "\n") or "(rỗng)"
end

