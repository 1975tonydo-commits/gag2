local function buySeedSweep()
    local count = 0
    if not (SeedPurchaseFn or RawSeedRemote) then
        if Config.DebugBuy then warn("[NTMT HUB] buySeedSweep: NO PURCHASE FN/REMOTE!") end
        return 0
    end
    local seeds = {}
    -- Mua TAT CA ON => lay het stock | OFF => chi lay seed co trong dropdown
    for _, seed in ipairs(getStockSeeds()) do
        if Config.BuyAllSeeds or whitelistAllows(Config.BuySeedWhitelist, seed) then
            table.insert(seeds, seed)
        end
    end
    if Config.DebugBuy then
        local wlCount = 0
        for _ in pairs(Config.BuySeedWhitelist) do wlCount = wlCount + 1 end
        print(("[NTMT HUB] buySeedSweep: %d seeds matched (whitelist=%d, sheckles=%d)"):format(
            #seeds, wlCount, getSheckles()))
        if #seeds == 0 then
            local stockAll = getStockSeeds()
            warn(("[NTMT HUB]   STOCK has %d seeds but whitelist matched 0!"):format(#stockAll))
        end
    end
    for _, seed in ipairs(seeds) do
        if count >= Config.MaxBuySeedsPerSweep then return count end
        local seedCost = getSeedCost(seed)
        local stockAmt = getSeedStock(seed)
        local amount = math.clamp(stockAmt, 0, Config.MaxBuySeedsPerSweep - count)
        if Config.DebugBuy then
            print(("[NTMT HUB] try seed=%s stock=%d cost=%s sheckles=%d"):format(
                seed, stockAmt, tostring(seedCost), getSheckles()))
        end
        for _ = 1, amount do
            if count >= Config.MaxBuySeedsPerSweep then return count end
            if seedCost and getSheckles() < seedCost then
                if Config.DebugBuy then warn("[NTMT HUB]   not enough Sheckles for "..seed) end
                break
            end
            if purchaseSeed(seed) then
                count = count + 1
            else
                if Config.DebugBuy then warn("[NTMT HUB]   purchaseSeed("..seed..") returned false") end
                break
            end
            task.wait(Config.BuySeedDelay)
        end
    end
    if Config.DebugBuy and count > 0 then
        print(("[NTMT HUB] buySeedSweep DONE: %d purchases fired"):format(count))
    end
    return count
end

local function buyGearSweep()
    if not (GearPurchaseFn or RawGearRemote) then
        if Config.DebugBuy then warn("[NTMT HUB] buyGearSweep: NO PURCHASE FN/REMOTE!") end
        return 0
    end
    local restockId = getGearRestockId()
    local bought = 0
    local wanted = getWantedGearNames()
    if Config.DebugBuy then
        print(("[NTMT HUB] buyGearSweep: %d gears wanted (restockId=%s)"):format(#wanted, tostring(restockId)))
    end
    for _, gearName in ipairs(wanted) do
        if bought >= Config.MaxBuyGearsPerSweep then return bought end
        if gearCompletedRestock[gearName] == restockId then
            -- skip
        else
            local remaining = math.min(getGearRemainingStock(gearName), Config.MaxBuyGearsPerSweep - bought)
            if remaining <= 0 then
                gearCompletedRestock[gearName] = restockId
            else
                local cost = getGearCost(gearName)
                if cost and getSheckles() < cost then return bought end
                local stop = false
                for _ = 1, remaining do
                    if cost and getSheckles() < cost then return bought end
                    local before = getGearInventoryCount(gearName)
                    if not purchaseGear(gearName) then stop = true; break end
                    local deadline = os.clock() + 0.8
                    local after = before
                    repeat
                        task.wait(0.04)
                        after = getGearInventoryCount(gearName)
                    until after > before or os.clock() >= deadline
                    if after <= before then
                        cost = getGearCost(gearName)
                        if cost and getSheckles() < cost then
                            gearInsufficientFundsFailures = gearInsufficientFundsFailures + 1
                            if gearInsufficientFundsFailures >= maxGearInsufficientFundsRetries then
                                return bought
                            end
                        else
                            gearInsufficientFundsFailures = 0
                        end
                        stop = true; break
                    end
                    local added = after - before
                    gearInsufficientFundsFailures = 0
                    bought = bought + added
                    BoughtGears[gearName] = (BoughtGears[gearName] or 0) + added
                    task.wait(Config.BuyGearDelay)
                end
                if stop then break end
                if getGearRemainingStock(gearName) <= 0 then
                    gearCompletedRestock[gearName] = restockId
                end
            end
        end
    end
    return bought
end

