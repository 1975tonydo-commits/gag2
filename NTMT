        sg.ResetOnSpawn = false
        sg.Parent = pg
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(0.8, 0, 0, 80)
        lbl.Position = UDim2.new(0.1, 0, 0, 20)
        lbl.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
