    Title = "Auto Sell",
    Desc  = "Tự động bán toàn bộ fruit trong inventory",
    Default = false,
    Callback = function(state)
        genv.ftgs_AutoSell = state
        if state then
            WindUI:Notify({ Title = "Auto Sell", Content = "Đã bật", Icon = "play", Duration = 2 })
        else
            WindUI:Notify({ Title = "Auto Sell", Content = "Đã tắt", Icon = "pause", Duration = 2 })
        end
    end
})

local sellInterval = 30
GAGTab:Slider({
    Title = "Chu kỳ Auto Sell (giây)",
    Step  = 5,
    Value = { Min = 10, Max = 300, Default = 30 },
    Callback = function(v) sellInterval = v end
