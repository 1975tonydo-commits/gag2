local function scanTools(filterFn)
    local found = {}
    for _, container in ipairs({ LocalPlayer.Character, LocalPlayer:FindFirstChild("Backpack") }) do
        if container then
            for _, item in ipairs(container:GetChildren()) do
                if item:IsA("Tool") and (not filterFn or filterFn(item)) then
                    table.insert(found, item)
                end
            end
        end
    end
    return found
end

local function findSeedToolByName(seedName)
    for _, tool in ipairs(scanTools(function(t)
        return t:GetAttribute("SeedTool") == seedName
    end)) do
        return tool
    end
    return nil
end

local function countSeedTools(seedName)
    local n = 0
    for _, tool in ipairs(scanTools(function(t)
        return t:GetAttribute("SeedTool") == seedName
    end)) do
        n = n + math.max(1, tonumber(tool:GetAttribute("Count")) or 1)
    end
    return n
end

local function getInventorySeedOrder()
    local names, seen = {}, {}
    for _, tool in ipairs(scanTools(function(t)
        return type(t:GetAttribute("SeedTool")) == "string"
    end)) do
        local seedName = tool:GetAttribute("SeedTool")
        if not seen[seedName] then
            seen[seedName] = true
            table.insert(names, seedName)
        end
    end
    return names
end

local function findGearTool(attrName, wantedName)
    local found = {}
    for _, tool in ipairs(scanTools(function(t)
        local n = t:GetAttribute(attrName)
        return type(n) == "string" and n ~= ""
    end)) do
        found[tool:GetAttribute(attrName)] = tool
    end
    if wantedName and found[wantedName] then
        return found[wantedName], wantedName
    end
    if type(wantedName) == "table" then
        for _, name in ipairs(wantedName) do
            if found[name] then return found[name], name end
        end
    end
    for _, name in ipairs(WATERING_CAN_PRIORITY) do
        if found[name] then return found[name], name end
    end
    return nil, nil
end

local function findShovelTool()
    for _, tool in ipairs(scanTools(function(t)
        return t:GetAttribute("Shovel") ~= nil or t.Name:lower():find("shovel")
    end)) do
        return tool, tool:GetAttribute("Shovel") or tool.Name
    end
    return nil, nil
end

