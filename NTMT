    local jobId = tostring(game.JobId or "")
    local clip = setclipboard or (Clipboard and Clipboard.set) or toclipboard
    if clip then pcall(clip, jobId) end
    notify("Job ID", jobId, "copy", 5)
end

local function scanAndFindPet(manual)
    if petFoundOnServer then
        if manual then notify("Find Pet", "Pet already found on this server", "check", 3) end
        return true
    end
    local list = getFindPetList()
    if #list == 0 then
        if manual then notify("Find Pet", "Select at least one pet to find", "circle-x", 3) end
        return false
    end
    for _, petName in ipairs(list) do
        if verifyPetOnServer(petName) then
            petFoundOnServer = true
            genv.ftgs_AutoFindPet = false
            notify("Find Pet", "Found " .. petName .. " on this server - staying here", "check", 5)
            return true
        end
    end
    if manual then
        notify("Find Pet", "Selected pet(s) not found on this server", "search", 3)
    end
    return false
end

