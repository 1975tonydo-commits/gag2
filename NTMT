-- Build text
local function buildSeedStockText()
    local items = getSeedShopItems()
    if not items then return "(Khong tim thay StockValues.SeedShop)" end
    local lines = {}
    -- Lay het seed (khong filter excluded de hien thi het stock thuc te)
    local list = {}
    for _, val in ipairs(items:GetChildren()) do
        if val:IsA("ValueBase") then
            local stock = tonumber(val.Value) or 0
            if stock > 0 then
                table.insert(list, { name = val.Name, stock = stock, cost = getSeedCost(val.Name) })
            end
        end
    end
    -- Sort by stock desc
    table.sort(list, function(a, b) return a.stock > b.stock end)
    for _, it in ipairs(list) do
        table.insert(lines, ("• %s | qty %d | %s sheckles"):format(
            it.name, it.stock, it.cost and tostring(it.cost) or "?"))
    end
    if #lines == 0 then return "(Khong co seed nao trong stock)" end
    return table.concat(lines, "\n")
end

local function buildGearStockText()
    local shop = getGearShopFolder()
    local items = shop and shop:FindFirstChild("Items")
    if not items then return "(Khong tim thay StockValues.GearShop)" end
    local list = {}
    for _, val in ipairs(items:GetChildren()) do
        if val:IsA("ValueBase") then
            local stock = tonumber(val.Value) or 0
            if stock > 0 then
                table.insert(list, { name = val.Name, stock = stock, cost = getGearCost(val.Name) })
            end
        end
    end
    table.sort(list, function(a, b) return a.stock > b.stock end)
    local lines = {}
    for _, it in ipairs(list) do
        table.insert(lines, ("• %s | qty %d | %s sheckles"):format(
            it.name, it.stock, it.cost and tostring(it.cost) or "?"))
    end
    if #lines == 0 then return "(Khong co gear nao trong stock)" end
    return table.concat(lines, "\n")
end

local function buildRestockText()
    local seedShop = Services.ReplicatedStorage:FindFirstChild("StockValues")
    seedShop = seedShop and seedShop:FindFirstChild("SeedShop")
    local seedNext = seedShop and seedShop:FindFirstChild("UnixNextRestock")
    local gearShop = getGearShopFolder()
    local gearNext = gearShop and gearShop:FindFirstChild("UnixNextRestock")
    local lines = {}
    if seedNext and tonumber(seedNext.Value) then
        local delta = tonumber(seedNext.Value) - os.time()
        if delta < 0 then delta = 0 end
        table.insert(lines, ("• Seed Shop: %dm %ds"):format(math.floor(delta / 60), delta % 60))
    end
    if gearNext and tonumber(gearNext.Value) then
        local delta = tonumber(gearNext.Value) - os.time()
        if delta < 0 then delta = 0 end
        table.insert(lines, ("• Gear Shop: %dm %ds"):format(math.floor(delta / 60), delta % 60))
    end
    if #lines == 0 then return "(Khong co timer)" end
    return table.concat(lines, "\n")
end

