-- Global toggle - set true de TAT CA teleport bypass dung tween
local useBypassTween = false
local tweenSpeed = 350  -- studs/giay (cang cao cang nhanh, thap = an toan hon)

-- Bypass tween: di chuyen muot nguoi choi den vi tri dich bang TweenService
-- thay vi set CFrame truc tiep (server kho detect hon)
local function bypassTween(targetCFrame, customSpeed)
    local char = LocalPlayer.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not (hrp and hum) then return false end

    local speed = customSpeed or tweenSpeed
    local distance = (hrp.Position - targetCFrame.Position).Magnitude
    if distance < 1 then
        hrp.CFrame = targetCFrame
        return true
    end
    local duration = math.clamp(distance / speed, 0.05, 5)

    -- Tat AutoRotate de tween khong bi xoay loan
    local oldAutoRotate = hum.AutoRotate
    hum.AutoRotate = false

    -- Tat platform stand de khong bi gravity keo xuong
    local oldPlatformStand = hum.PlatformStand
    hum.PlatformStand = true

    local tweenInfo = TweenInfo.new(
        duration,
        Enum.EasingStyle.Linear,
        Enum.EasingDirection.Out
    )
    local tween = Services.TweenService:Create(hrp, tweenInfo, { CFrame = targetCFrame })
    tween:Play()

    -- Wait tween xong (toi da duration + 0.1s safety)
    local done = false
    tween.Completed:Connect(function() done = true end)
    local deadline = os.clock() + duration + 0.1
    while not done and os.clock() < deadline do
        Services.RunService.Heartbeat:Wait()
        -- Reset velocity de khong bi physics day
        pcall(function() hrp.Velocity = Vector3.zero end)
    end

    -- Restore
    hum.AutoRotate = oldAutoRotate
    hum.PlatformStand = oldPlatformStand

    -- Bao dam toi noi (tween co the bi off 1 chut)
    pcall(function() hrp.CFrame = targetCFrame end)
    return true
end

-- Wrapper: dung bypass tween neu useBypassTween = true, else instant TP
local function smartTeleport(targetCFrame, customSpeed)
    if useBypassTween then
        return bypassTween(targetCFrame, customSpeed)
    end
    local hrp = getRoot(LocalPlayer)
    if hrp then
        pcall(function() hrp.CFrame = targetCFrame end)
        return true
    end
    return false
end


