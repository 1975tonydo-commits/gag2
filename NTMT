local function getSeedShopItems()
    local stock = Services.ReplicatedStorage:FindFirstChild("StockValues")
    local seedShop = stock and stock:FindFirstChild("SeedShop")
    return seedShop and seedShop:FindFirstChild("Items")
end

local function getSeedStock(seedName)
    local items = getSeedShopItems()
    local value = items and items:FindFirstChild(seedName)
    return value and tonumber(value.Value) or 0
end

local function getStockSeeds()
    local items = getSeedShopItems()
    local names = {}
    if not items then return names end
    for _, value in ipairs(items:GetChildren()) do
        if value:IsA("ValueBase") and tonumber(value.Value) and value.Value > 0
            and not isSeedExcluded(value.Name) then
            table.insert(names, value.Name)
        end
    end
    table.sort(names, function(a, b) return getSeedStock(a) > getSeedStock(b) end)
    return names
