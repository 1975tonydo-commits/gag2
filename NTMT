local ShovelWhitelist = {}

local function tryShovelLowest()
    if not Networking or not Networking.Shovel or not Networking.Shovel.UseShovel then return end
    local plot = getCachedOwnedPlot()
    if not plot then return end
    local plantsFolder = plot:FindFirstChild("Plants")
    if not plantsFolder then return end

    local targetId
    local lowestRank = math.huge
    for _, plant in ipairs(plantsFolder:GetChildren()) do
        local pid = plant:GetAttribute("PlantId")
        if pid then
            local seedName = plant:GetAttribute("SeedName") or plant:GetAttribute("PlantName") or ""
            if next(ShovelWhitelist) == nil or ShovelWhitelist[seedName] then
                local mutation = plant:GetAttribute("Mutation") or "Normal"
                local rank = 1
                if mutation == "Gold" then rank = 2
                elseif mutation == "Rainbow" then rank = 3 end
                if seedName ~= "" then
                    local sd = getSeedData(seedName)
                    local rarity = sd and sd.Rarity or "Common"
                    local rarityRank = ({ Secret = 1, Super = 2, Mythic = 3, Legendary = 4, Epic = 5, Rare = 6, Uncommon = 7, Common = 8 })[rarity] or 99
                    rank = rank + rarityRank * 10
                end
                if rank < lowestRank then
                    lowestRank = rank
                    targetId = pid
                end
            end
        end
    end

    if not targetId then return end
    local shovelTool, shovelName = findShovelTool()
    if not shovelTool then return end
    equipTool(shovelTool)
    safeFire(Networking.Shovel.UseShovel, targetId, "", shovelName, shovelTool)
