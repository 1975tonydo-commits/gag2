local MAIL_GIFT_CATEGORIES = { "Seeds", "Sprinklers", "WateringCans", "Pets", "HarvestedFruits", "Gnomes", "Crates", "SeedPacks" }
local MAIL_MAX_PER_GIFT = 20

local function mergeMailBatchEntry(batch, entry)
    for _, existing in batch do
        if existing.Category == entry.Category and existing.ItemKey == entry.ItemKey then
            existing.Count = (existing.Count or 1) + (entry.Count or 1)
            return
        end
    end
    batch[#batch + 1] = entry
end

local function splitMailBatch(batch, maxTotal)
    local chunks, current, currentTotal = {}, {}, 0
    maxTotal = maxTotal or MAIL_MAX_PER_GIFT
    for _, item in batch do
        local remaining = item.Count or 1
        while remaining > 0 do
            if currentTotal >= maxTotal then
                chunks[#chunks + 1] = current
                current, currentTotal = {}, 0
            end
            local space = maxTotal - currentTotal
            local take = math.min(remaining, space)
            current[#current + 1] = { Category = item.Category, ItemKey = item.ItemKey, Count = take }
            currentTotal = currentTotal + take
            remaining = remaining - take
        end
    end
    if #current > 0 then chunks[#chunks + 1] = current end
    return chunks
end

local function lookupMailUserId(username)
    if type(username) ~= "string" or username == "" then return nil end
    username = username:gsub("^%s*@?", ""):gsub("%s+$", "")
    if not Networking or not Networking.Mailbox or not Networking.Mailbox.LookupPlayer then return nil end
    local ok, userId = pcall(function()
        return Networking.Mailbox.LookupPlayer:Fire(username)
    end)
    if ok then return userId end
    return nil
end

local function sendMailBatch(userId, batch, note)
    if not Networking or not Networking.Mailbox or not Networking.Mailbox.SendBatch then return false end
    local ok, result = pcall(function()
        return Networking.Mailbox.SendBatch:Fire(userId, batch, note or "gift")
    end)
    return ok and result ~= false
end

local function resolveMailSeedBatch(seedName, amount)
    local batch = {}
    local inv = gearReplica and gearReplica.Data and gearReplica.Data.Inventory
    local bucket = inv and inv.Seeds
    local owned = bucket and tonumber(bucket[seedName]) or 0
    if owned <= 0 then
        owned = countSeedTools(seedName)
    end
    local sendCount = amount
    if type(amount) ~= "number" or amount <= 0 then sendCount = owned end
    sendCount = math.min(sendCount, owned)
    if sendCount > 0 then
        table.insert(batch, { Category = "Seeds", ItemKey = seedName, Count = sendCount })
    end
    return batch
end

local function resolveMailGearBatch(gearName, amount)
    local batch = {}
    local owned = getGearInventoryCount(gearName)
    local sendCount = amount
    if type(amount) ~= "number" or amount <= 0 then sendCount = owned end
    sendCount = math.min(sendCount, owned)
    if sendCount > 0 then
        local category = "Sprinklers"
        if gearName:lower():find("watering") then category = "WateringCans" end
        table.insert(batch, { Category = category, ItemKey = gearName, Count = sendCount })
    end
    return batch
end

local function performSendMail()
    if isSendingMail then return false end
    if mailUsername == "" then
        notify("Mail", "Enter a username first", "circle-x", 3)
        return false
    end
    local userId = lookupMailUserId(mailUsername)
    if not userId then
        notify("Mail", "Player not found: " .. mailUsername, "circle-x", 3)
        return false
    end
    local batch = {}
    for _, entry in ipairs(resolveMailSeedBatch(mailSeedName, mailSeedAmount)) do
        table.insert(batch, entry)
    end
    for _, entry in ipairs(resolveMailGearBatch(mailGearName, mailGearAmount)) do
        table.insert(batch, entry)
    end
    if #batch == 0 then
        notify("Mail", "Nothing to send", "circle-x", 3)
        return false
    end
    isSendingMail = true
    local chunks = splitMailBatch(batch, MAIL_MAX_PER_GIFT)
    local sentAny = false
    for i, chunk in ipairs(chunks) do
        local ok = sendMailBatch(userId, chunk, "NTMT gift")
        if ok then sentAny = true end
        if i < #chunks then task.wait(1.2) end
    end
    isSendingMail = false
    if sentAny then
        notify("Mail", "Mail sent to " .. mailUsername, "check", 3)
    else
        notify("Mail", "Mail failed", "circle-x", 3)
    end
    return sentAny
end

