    for _, val in ipairs(items:GetChildren()) do
        if val:IsA("ValueBase") then
            local stock = getSeedRemainingStock(val.Name)
            if stock > 0 then
                local price = getSeedCost(val.Name)
                table.insert(list, {
                    name = val.Name,
                    stock = stock,
                    price = price and tostring(price) or "?",
                })
            end
        end
    end
    table.sort(list, function(a, b) return a.name < b.name end)
