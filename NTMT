task.spawn(function()
    while true do
        if genv.ftgs_AutoHarvest then
            pcall(function()
                for _, plant in ipairs(getHarvestablePlants()) do
                    if not genv.ftgs_AutoHarvest then break end
                    harvestPlant(plant)
                end
            end)
        end
        task.wait(harvestInterval)
    end
end)

task.spawn(function()
    while true do
        task.wait(sellInterval)
        if genv.ftgs_AutoSell then pcall(sellInventory) end
    end
end)

local lastExpand = 0
task.spawn(function()
    while true do
        if genv.ftgs_AutoExpand and os.clock() - lastExpand >= expandInterval then
            lastExpand = os.clock()
            pcall(tryExpandGarden)
        end
        task.wait(1)
    end
end)

local lastSprinkler = 0
task.spawn(function()
    while true do
        if genv.ftgs_AutoSprinkler and os.clock() - lastSprinkler >= sprinklerInterval then
            lastSprinkler = os.clock()
            pcall(trySprinklerAndWater)
        end
        task.wait(0.5)
    end
end)

local lastMail = 0
task.spawn(function()
    while true do
        if genv.ftgs_AutoMail and os.clock() - lastMail >= mailInterval then
            local ok, sent = pcall(tryAutoMailLoop)
            if ok and sent then
                lastMail = os.clock()
            end
        end
        task.wait(0.5)
    end
end)

task.spawn(function()
    while true do
        if genv.ftgs_AutoSteal and isNightTime() then
            local target = select(1, getMostValuableSteal())
            if target then
                pcall(stealFruit, target)
                stealBurstCount = stealBurstCount + 1
                if stealReturnAfter and stealBurstCount >= stealsBeforeReturn then
                    stealBurstCount = 0
                    pcall(returnToOwnPlot)
                end
                task.wait(0.02)
            else
                stealBurstCount = 0
                task.wait(0.15)
            end
        else
            stealBurstCount = 0
            task.wait(0.2)
        end
    end
end)

local lastPetCatch = 0
task.spawn(function()
    while true do
        if petBuyEnabled() and not isCatchingPet and os.clock() - lastPetCatch >= petCatchInterval then
            lastPetCatch = os.clock()
            if genv.ftgs_AutoBuyAllPet then
                pcall(tryBuyAllPets)
            elseif genv.ftgs_AutoBuyPet then
                pcall(tryBuySelectedPet)
            end
        end
        task.wait(0.35)
    end
end)

