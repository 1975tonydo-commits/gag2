local function tr(key)
    local pack = I18N[currentLang] or I18N.English
    return pack[key] or I18N.English[key] or key
end

local function registerUI(el, key, kind)
    table.insert(UIRegistry, { el = el, key = key, kind = kind or "title" })
end

local function setUIElementText(el, text)
    if not el then return end
    pcall(function()
        if type(el.SetTitle) == "function" then el:SetTitle(text) end
    end)
    pcall(function()
        if type(el.SetDesc) == "function" then el:SetDesc(text) end
    end)
    pcall(function()
        if type(el.Update) == "function" then el:Update({ Title = text }) end
    end)
    pcall(function()
        if type(el.SetText) == "function" then el:SetText(text) end
    end)
end

local function applyTranslations()
    for _, entry in ipairs(UIRegistry) do
        local el, key, kind = entry.el, entry.key, entry.kind
        if el then
            local text = tr(key)
            if kind == "desc" then
                pcall(function()
                    if type(el.SetDesc) == "function" then el:SetDesc(text) end
                end)
            elseif kind == "tab" then
                setUIElementText(el, text)
            else
                setUIElementText(el, text)
            end
        end
    end
    pcall(function()
        if Window and type(Window.SetTitle) == "function" then
            Window:SetTitle("NTMT HUB | Grow a Garden 2")
        end
    end)
end

