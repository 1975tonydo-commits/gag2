local function getBuyablePets()
    local out = {}  -- list { model, petName, prompt }
    local pets = Services.Workspace:FindFirstChild("Pets")
        or Services.Workspace:FindFirstChild("WildPets")
        or Services.Workspace:FindFirstChild("ActivePets")
        or Services.Workspace
    if not pets then return out end

    -- Tim pet trong cac container co the
    local function scan(container, depth)
        if not container or depth > 4 then return end
        for _, child in ipairs(container:GetChildren()) do
            local petName = getPetNameFromModel(child)
            if petName then
                local prompt = child:FindFirstChildWhichIsA("ProximityPrompt", true)
                if prompt then
                    local at = (prompt.ActionText or ""):lower()
                    local ot = (prompt.ObjectText or ""):lower()
                    -- ProximityPrompt phai la "Buy"/"Purchase"/"Adopt" hoac chua ten pet
                    if at:find("buy") or at:find("purchase") or at:find("adopt") or at:find("claim") or
                       ot:find("buy") or ot:find("purchase") or ot:find(petLowerName(petName), 1, true) then
                        table.insert(out, { model = child, petName = petName, prompt = prompt })
                    end
                end
            else
                -- Recurse vao folder (nhung khong vao model)
                if child:IsA("Folder") or child:IsA("Configuration") then
                    scan(child, depth + 1)
                end
            end
        end
    end

    scan(pets, 0)

    -- Backup: scan workspace neu khong tim duoc trong pet folders
    if #out == 0 and pets ~= Services.Workspace then
        scan(Services.Workspace, 0)
    end
    return out
end

local function buyPet(petInfo)
    local model = petInfo.model
    local prompt = petInfo.prompt
    if not model or not prompt then return false end
    local hrp = getRoot(LocalPlayer)
    if not hrp then return false end

    -- TP toi pet
    local part = getPartFromObj(model)
    if not part then return false end
    local origCF = hrp.CFrame
    pcall(function() hrp.CFrame = part.CFrame + Vector3.new(0, 3, 0) end)
    task.wait(0.1)

    -- Fire prompt (cho moi executor)
    local fired = false
    if fireproximityprompt then
        local ok = pcall(fireproximityprompt, prompt, 0)
        if ok then fired = true end
    end
    if not fired then
        -- Fallback: HoldDuration + InputHoldBegin
        pcall(function()
            local oldHold = prompt.HoldDuration
            prompt.HoldDuration = 0
            prompt:InputHoldBegin()
            task.wait(0.05)
            prompt:InputHoldEnd()
            prompt.HoldDuration = oldHold
        end)
    end
    task.wait(0.15)
    pcall(function() hrp.CFrame = origCF end)

    BoughtPets[petInfo.petName] = (BoughtPets[petInfo.petName] or 0) + 1
    return true
end

