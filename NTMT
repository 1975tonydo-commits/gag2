local function buildRestockText()
    local stockRoot = Services.ReplicatedStorage:FindFirstChild("StockValues")
    local seedShop = stockRoot and stockRoot:FindFirstChild("SeedShop")
    local seedNext = seedShop and seedShop:FindFirstChild("UnixNextRestock")
    local gearShop = getGearShopFolder()
    local gearNext = gearShop and gearShop:FindFirstChild("UnixNextRestock")
