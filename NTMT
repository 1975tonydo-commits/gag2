    local fireFn = fireproximityprompt or rawget(genv, "fireproximityprompt")
    if typeof(fireFn) == "function" then
        local ok = pcall(fireFn, prompt, prompt.HoldDuration)
        if ok then return true end
        ok = pcall(fireFn, prompt)
        if ok then return true end
    end
    return pcall(function()
        prompt:InputHoldBegin()
        if prompt.HoldDuration > 0 then
            task.wait(prompt.HoldDuration + 0.08)
