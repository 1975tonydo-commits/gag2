    forTame = forTame == true
    for i = 1, passes do
        local hit = scanWildPetsForTarget(targetName, forTame)
        if hit then return hit end
        task.wait(0.5 + i * 0.08)
    end
    return nil
end

local function catchWildPetRef(hit, waitSeconds)
    if not hit or not Networking or not Networking.Pets then return false end
    if isCatchingPet then return false end
    isCatchingPet = true
    waitSeconds = waitSeconds or 8

    local hrp = getRoot(LocalPlayer)
    local savedCF = hrp and hrp.CFrame
    local root = getModelRoot(hit.model)
    if hrp and root then
        pcall(function() hrp.CFrame = CFrame.new(root.Position + Vector3.new(0, 3, 0)) end)
        task.wait(0.35)
    end

    local tameDone = false
    local resultConn
    if Networking.Pets.WildPetTameResult and Networking.Pets.WildPetTameResult.OnClientEvent then
        resultConn = Networking.Pets.WildPetTameResult.OnClientEvent:Connect(function(_, userId)
            if userId == LocalPlayer.UserId then tameDone = true end
        end)
    end

    safeFire(Networking.Pets.WildPetTame, hit.ref)

    local deadline = os.clock() + waitSeconds
    while not tameDone and os.clock() < deadline do
        if hit.ref and not hit.ref.Parent then tameDone = true break end
        if hit.model and not hit.model.Parent then tameDone = true break end
        task.wait(0.1)
    end
    if resultConn then resultConn:Disconnect() end
    if tameDone then task.wait(0.4) end

    if hrp and savedCF then
        pcall(function() hrp.CFrame = savedCF end)
    end
    isCatchingPet = false
    return tameDone
end

