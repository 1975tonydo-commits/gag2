local collectInterval = 0.4
local collectReturn   = true
local collectMaxRange = 250
local collectKeywords = {
    gold = true, rainbow = true, legend = false,
    mythic = false, special = false, drop = true,
}

local DROP_FOLDER_NAMES = {
    "Drops", "DroppedItems", "Items", "Pickups", "WorldDrops", "Loot",
}

local function findDropFolders()
    local result = {}
    for _, name in ipairs(DROP_FOLDER_NAMES) do
        local f = Services.Workspace:FindFirstChild(name)
        if f then table.insert(result, f) end
    end
    return result
end

local function nameMatchesKeyword(name)
    name = name:lower()
    for k, enabled in pairs(collectKeywords) do
        if enabled and name:find(k, 1, true) then return true end
    end
    return false
end

local function isValidDrop(item)
    if not item or not item.Parent then return false end
    if Gardens and item:IsDescendantOf(Gardens) then return false end
    if LocalPlayer.Character and item:IsDescendantOf(LocalPlayer.Character) then return false end
    local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
    if not prompt then return false end
    local actionText = (prompt.ActionText or ""):lower()
    local objectText = (prompt.ObjectText or ""):lower()
    if not (actionText:find("pick") or actionText:find("collect")
         or objectText:find("pick") or objectText:find("collect") or objectText:find("drop")
         or nameMatchesKeyword(item.Name)) then
        return false
    end
    return true, prompt
end

local function collectItem(item, prompt)
    local hrp = getRoot(LocalPlayer)
    if not hrp then return end
    local root = getPartFromObj(item)
    if not root then return end
    local dist = (root.Position - hrp.Position).Magnitude
    if dist > collectMaxRange then return end
    pcall(function() hrp.CFrame = CFrame.new(root.Position + Vector3.new(0, 3, 0)) end)
    task.wait(0.06)
    if prompt and fireproximityprompt then
        pcall(fireproximityprompt, prompt, 0)
    end
end

local function scanDrops()
    local drops = {}
    local folders = findDropFolders()
    if #folders > 0 then
        for _, folder in ipairs(folders) do
            for _, item in ipairs(folder:GetChildren()) do
                local ok, prompt = isValidDrop(item)
                if ok then table.insert(drops, { item = item, prompt = prompt }) end
            end
        end
    else
        for _, item in ipairs(Services.Workspace:GetChildren()) do
            if item:IsA("Model") or item:IsA("Tool") or item:IsA("BasePart") then
                local ok, prompt = isValidDrop(item)
                if ok then table.insert(drops, { item = item, prompt = prompt }) end
            end
        end
    end
    return drops
end

