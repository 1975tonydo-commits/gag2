local function plotUnlocked(player)
    local plot = nil
    for _, p in ipairs(Gardens:GetChildren()) do
        if p:GetAttribute("OwnerUserId") == player.UserId then plot = p break end
    end
    if not plot then return true end
    local visual = plot:FindFirstChild("Visual")
    local area = visual and visual:FindFirstChild("PlotSizeReferenceVisual")
    if not area then return true end
    for _, touching in ipairs(Services.Workspace:GetPartBoundsInBox(area.CFrame, area.Size)) do
        if player.Character and touching:IsDescendantOf(player.Character) then
            return false
        end
    end
    return true
end

local function calculateValue(fruit)
    if not FruitValueCalc then return fruit:GetAttribute("Age") or 1 end
    local name = fruit:GetAttribute("CorePartName") or fruit:GetAttribute("PlantName")
    local size = fruit:GetAttribute("SizeMulti") or fruit:GetAttribute("Age")
    local mut  = fruit:GetAttribute("Mutation")
    local ok, val = pcall(FruitValueCalc, name, size, mut, LocalPlayer, 1)
    return ok and val or 0
end

local function plotHasStealableFruits(plot)
    local plants = plot:FindFirstChild("Plants")
    if not plants then return false end
    for _, plant in ipairs(plants:GetChildren()) do
        local fruits = plant:FindFirstChild("Fruits")
        if fruits then
            for _, fr in ipairs(fruits:GetChildren()) do
                local hp = fr:FindFirstChild("HarvestPart")
                if hp and hp:FindFirstChild("StealPrompt") then return true end
            end
        else
            local hp = plant:FindFirstChild("HarvestPart")
            if hp and hp:FindFirstChild("StealPrompt") then return true end
        end
    end
    return false
end

local function isPlotStealable(plot)
    if not plot then return false end
    local ownerId = plot:GetAttribute("OwnerUserId")
    if not ownerId or ownerId == 0 then
        return plotHasStealableFruits(plot)
    end
    local owner = Services.Players:GetPlayerByUserId(ownerId)
    if not owner or owner == LocalPlayer then return false end
    local hum = getHumanoid(owner)
    if hum and hum.Sit then return false end
    return plotUnlocked(owner) and plotHasStealableFruits(plot)
end

local function getMostValuableSteal()
    local bestValue, bestItem = 0, nil
    for _, plot in ipairs(Gardens:GetChildren()) do
        if not isPlotStealable(plot) then continue end
        local plants = plot:FindFirstChild("Plants")
        if not plants then continue end
        for _, plant in ipairs(plants:GetChildren()) do
            local fruits = plant:FindFirstChild("Fruits")
            local candidates = {}
            if fruits then
                for _, fr in ipairs(fruits:GetChildren()) do
                    local hp = fr:FindFirstChild("HarvestPart")
                    if hp and hp:FindFirstChild("StealPrompt") then
                        table.insert(candidates, fr)
                    end
                end
            else
                local hp = plant:FindFirstChild("HarvestPart")
                if hp and hp:FindFirstChild("StealPrompt") then
                    table.insert(candidates, plant)
                end
            end
            for _, c in ipairs(candidates) do
                local v = calculateValue(c)
                if v > bestValue then bestValue, bestItem = v, c end
            end
        end
    end
    return bestItem, bestValue
end

