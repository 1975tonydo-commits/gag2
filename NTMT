local function isItemDrop(item)
    if not item or not item.Parent then return false end
    if Gardens and item:IsDescendantOf(Gardens) then return false end
    if LocalPlayer.Character and item:IsDescendantOf(LocalPlayer.Character) then return false end
    local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
    if not prompt then return false end
    local actionText = (prompt.ActionText or ""):lower()
    if actionText:find("pick") or actionText:find("collect") then
        -- Loại trừ rainbow/gold (đã có toggle riêng)
        local n = item.Name:lower()
        if n:find("rainbow") or n:find("gold") then return false end
        return true
    end
    return false
end

local function fireProximityPromptStrong(prompt)
    if not prompt or not prompt:IsA("ProximityPrompt") then return false end
    if fireproximityprompt then
        local ok = pcall(fireproximityprompt, prompt, prompt.HoldDuration)
        if ok then return true end
        ok = pcall(fireproximityprompt, prompt)
        if ok then return true end
    end
    -- Fallback: InputHoldBegin/End
    local ok = pcall(function()
        local oldHold = prompt.HoldDuration
        prompt.HoldDuration = 0
        prompt:InputHoldBegin()
        task.wait(0.05)
        prompt:InputHoldEnd()
        prompt.HoldDuration = oldHold
    end)
    return ok
end

local function fireCollect(item)
    local hrp = getRoot(LocalPlayer)
    if not hrp then return end
    local part = getPartFromObj(item)
    local pos
    if part then
        pos = part.Position
    elseif item:IsA("Model") then
        pos = item:GetPivot().Position
    end
    if not pos then return end
    local origCF = hrp.CFrame
    pcall(function() hrp.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0)) end)
    task.wait(0.15)
    local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
    if prompt then
        fireProximityPromptStrong(prompt)
        task.wait(prompt.HoldDuration + 0.1)
    end
    pcall(function() hrp.CFrame = origCF end)
end

