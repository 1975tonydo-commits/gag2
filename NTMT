    elseif rem:IsA("RemoteFunction") then
        return pcall(function() rem:InvokeServer(name) end)
    end
    return false
end

local function buySeed(name, amount)
    local rem = cachedBuySeedRemote or findGameEventRemote(BUY_SEED_NAMES)
    cachedBuySeedRemote = rem
    if rem then
        for _ = 1, (amount or 1) do fireBuy(rem, name) end
        return true
    end
    if Networking then
        for _, path in ipairs({ {"Shop","BuySeedStock"}, {"Shop","BuySeed"}, {"Garden","BuySeed"}, {"Shop","Buy_Seed"} }) do
            local fn = (Networking[path[1]] or {})[path[2]]
            if fn and fn.Fire then
                for _ = 1, (amount or 1) do
                    pcall(function() fn:Fire(name) end)
                end
                return true
            end
        end
    end
    return false
end

local function buyGear(name, amount)
    local rem = cachedBuyGearRemote or findGameEventRemote(BUY_GEAR_NAMES)
    cachedBuyGearRemote = rem
    if rem then
