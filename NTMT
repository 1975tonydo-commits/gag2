    Icon  = "dollar-sign",
    Callback = function()
        local ok = sellInventory()
        WindUI:Notify({
            Title = ok and "Sell All" or "Lỗi",
            Content = ok and "Đã gửi lệnh bán" or "Không tìm thấy RemoteEvent Sell",
            Icon = ok and "circle-check" or "circle-x",
            Duration = 3,
        })
    end
})

task.spawn(function()
    while task.wait(harvestInterval) do
        if genv.ftgs_AutoHarvest then
            for _, farm in ipairs(getOwnedFarms()) do
                if not genv.ftgs_AutoHarvest then break end
                for _, fruit in ipairs(getFruitsInFarm(farm)) do
                    if not genv.ftgs_AutoHarvest then break end
                    pcall(harvestFruit, fruit)
                end
            end
        end
    end
end)

task.spawn(function()
    while true do
        task.wait(sellInterval)
        if genv.ftgs_AutoSell then
            pcall(sellInventory)
        end
    end
end)

