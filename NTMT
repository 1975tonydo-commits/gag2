GAGTab:Section({ Title = "Anti-Steal (Shovel)" })

genv.ftgs_AntiSteal = false
local antiStealInterval = 0.3

local function findShovel()
    -- Tìm shovel trong character (đang cầm)
    if LocalPlayer.Character then
        for _, t in ipairs(LocalPlayer.Character:GetChildren()) do
            if t:IsA("Tool") and t.Name:lower():find("shovel") then
                return t, true  -- second value = equipped
            end
        end
    end
    -- Tìm trong backpack
    local bp = LocalPlayer:FindFirstChild("Backpack")
    if bp then
        for _, t in ipairs(bp:GetChildren()) do
            if t:IsA("Tool") and t.Name:lower():find("shovel") then
                return t, false
            end
        end
    end
    return nil
end

local function equipShovel()
    local tool, equipped = findShovel()
    if not tool then return false end
    if equipped then return true end
    local hum = getHumanoid(LocalPlayer)
    if hum then
        pcall(function() hum:EquipTool(tool) end)
        return true
    end
    return false
end

-- Detect player đang đứng trong plot của mình (kẻ ăn cắp)
local function findStealersInPlot()
    local plot = getOwnedPlot()
    if not plot then return {} end
    local visual = plot:FindFirstChild("Visual")
    local area = visual and visual:FindFirstChild("PlotSizeReferenceVisual")
    if not area then return {} end

    local stealers = {}
    local halfX = area.Size.X / 2
    local halfZ = area.Size.Z / 2
    for _, p in ipairs(Services.Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local root = getRoot(p)
            if root then
                local lp = area.CFrame:PointToObjectSpace(root.Position)
                if math.abs(lp.X) < halfX and math.abs(lp.Z) < halfZ then
                    table.insert(stealers, p)
                end
            end
        end
    end
    return stealers
end

local function attackPlayer(target)
    local targetRoot = getRoot(target)
    local myRoot = getRoot(LocalPlayer)
    if not (targetRoot and myRoot) then return end

    -- TP toi player (bypass tween neu bat)
    smartTeleport(targetRoot.CFrame + Vector3.new(0, 0, 2))
    task.wait(0.05)

    -- Equip shovel nếu chưa
    equipShovel()
    task.wait(0.05)

    -- Activate shovel (hit) nhiều lần
    local char = LocalPlayer.Character
    if char then
        local tool = char:FindFirstChildOfClass("Tool")
        if tool then
            for _ = 1, 3 do
                pcall(function() tool:Activate() end)
                task.wait(0.05)
            end
        end
    end
end

