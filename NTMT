local function findSellPrompts()
    local out = {}
    for _, prompt in ipairs(Services.Workspace:GetDescendants()) do
        if prompt:IsA("ProximityPrompt") then
            local txt = ((prompt.ActionText or "") .. " " .. (prompt.ObjectText or "")):lower()
            if txt:find("sell") then
                table.insert(out, prompt)
            end
        end
    end
    return out
end

local function getPromptAnchor(prompt)
    local p = prompt.Parent
    while p and not (p:IsA("BasePart") or p:IsA("Model")) do
        p = p.Parent
    end
    if not p then return nil end
    if p:IsA("Model") then
        return p.PrimaryPart or p:FindFirstChildWhichIsA("BasePart", true)
    end
    return p
end

local function findSellPosition()
    if genv.ftgs_sellPos then return genv.ftgs_sellPos end

    local prompts = findSellPrompts()
    if #prompts > 0 then
        local anchor = getPromptAnchor(prompts[1])
        if anchor then return anchor.CFrame + Vector3.new(0, 3, 0) end
    end

    for _, obj in ipairs(Services.Workspace:GetDescendants()) do
        if (obj:IsA("Model") or obj:IsA("BasePart")) then
            if obj.Name:lower():find("sell") then
                local part = obj:IsA("BasePart") and obj
                    or (obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart", true))
                if part then return part.CFrame + Vector3.new(0, 3, 0) end
            end
        end
    end
    return nil
end

local function findNetworkingSellMethods()
    local out = {}
    if not Networking then return out end

    local function walk(tbl, path, depth)
        if depth > 4 then return end
        if type(tbl) ~= "table" then return end
        for k, v in pairs(tbl) do
            local key = tostring(k)
            local currentPath = path .. "." .. key
            if key:lower():find("sell") then
                if type(v) == "table" and v.Fire then
                    table.insert(out, { path = currentPath, fn = v })
                elseif type(v) == "function" then
                    table.insert(out, { path = currentPath, fn = v })
                end
            end
            if type(v) == "table" and v ~= tbl then
                pcall(walk, v, currentPath, depth + 1)
            end
        end
    end
    pcall(walk, Networking, "Networking", 1)
    return out
end

