    for _, it in ipairs(list) do
        table.insert(lines, string.format("%s x%d | %s", it.name, it.stock, it.price))
    end
    if #lines == 0 then return "No gear in stock" end
    return table.concat(lines, "\n")
end

local function universalHttpPost(url, jsonBody)
    local req = (syn and syn.request) or (http and http.request) or http_request or request or (fluxus and fluxus.request)
    if req then
        local res = req({
            Url = url, Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = jsonBody,
        })
        return res and (res.StatusCode or res.Status or 0)
    end
    local ok = pcall(function()
        Services.HttpService:PostAsync(url, jsonBody, Enum.HttpContentType.ApplicationJson)
    end)
    return ok and 200 or 0
end

local function jsonEncode(t)
    local ok, s = pcall(function() return Services.HttpService:JSONEncode(t) end)
    return ok and s or "{}"
end

local WEATHER_NAMES = { "Rain", "Lightning", "Rainbow", "Snowfall", "Starfall", "Aurora Borealis", "Blood Moon", "Night", "Day" }

local function findActiveWeather()
    local weather = Services.Workspace:GetAttribute("ActiveWeather")
    if type(weather) == "string" and weather ~= "" then
        return weather
    end
    weather = Services.ReplicatedStorage:GetAttribute("ActiveWeather")
    if type(weather) == "string" and weather ~= "" then
        return weather
    end
    local phase = Services.Workspace:GetAttribute("ActivePhase")
    if type(phase) == "string" and phase ~= "" and phase ~= "Day" then
        return phase
    end
    local night = Services.ReplicatedStorage:FindFirstChild("Night")
    if night and night.Value == true then
        return "Night"
    end
    return "Day"
end

local function findWeatherEndTime()
    local phaseEnd = Services.Workspace:GetAttribute("PhaseDuration")
    if phaseEnd then
        local now = (Services.Workspace.GetServerTimeNow and Services.Workspace:GetServerTimeNow()) or os.time()
        local remain = math.max(0, math.floor(tonumber(phaseEnd) - now))
        return string.format("%dm %ds", math.floor(remain / 60), remain % 60)
    end
    return "N/A"
end

local function getInventorySnapshot()
    local lines = {}
    if gearReplica and gearReplica.Data and gearReplica.Data.Inventory then
        for category, bucket in pairs(gearReplica.Data.Inventory) do
            if type(bucket) == "table" then
                for key, entry in pairs(bucket) do
                    local count = type(entry) == "number" and entry or (type(entry) == "table" and 1 or 0)
                    if count > 0 then
                        table.insert(lines, string.format("[%s] %s x%d", tostring(category), tostring(key), count))
                    end
                end
            end
        end
    end
    if #lines == 0 then
        for _, tool in ipairs(scanTools()) do
            table.insert(lines, tool.Name)
        end
    end
    return lines, #lines
end

local function buildPairedBuyLines(maxLines)
    local seedList, gearList = {}, {}
    for name, amt in pairs(BoughtSeeds) do
        if amt > 0 then table.insert(seedList, name .. " x" .. amt) end
    end
    for name, amt in pairs(BoughtGears) do
        if amt > 0 then table.insert(gearList, name .. " x" .. amt) end
    end
    table.sort(seedList)
    table.sort(gearList)
    local lines = {}
    local rows = math.max(#seedList, #gearList)
    maxLines = maxLines or 8
    for i = 1, math.min(rows, maxLines) do
        local s = seedList[i] or ""
        local g = gearList[i] or ""
        if s ~= "" and g ~= "" then
            table.insert(lines, s .. " | " .. g)
        elseif s ~= "" then
            table.insert(lines, s)
        elseif g ~= "" then
            table.insert(lines, g)
        end
    end
    if #lines == 0 then table.insert(lines, "none") end
    return lines
end

local function buildPetBuyLines()
    local lines = {}
    for name, amt in pairs(BoughtPets) do
        if amt > 0 then table.insert(lines, name .. " x" .. amt) end
    end
    table.sort(lines)
    if #lines == 0 then table.insert(lines, "none") end
    return lines
end

local function buildStolenFruitText()
    local parts = {}
    for name, amt in pairs(StolenFruits) do
        if amt > 0 then table.insert(parts, name .. " x" .. amt) end
    end
    table.sort(parts)
    if #parts == 0 then return "none" end
    return table.concat(parts, ", ")
end

local function buildEmbed()
    local accountName = LocalPlayer.DisplayName ~= LocalPlayer.Name
        and (LocalPlayer.DisplayName .. " (@" .. LocalPlayer.Name .. ")") or LocalPlayer.Name
    local invItems = getInventorySnapshot()
    local invText = #invItems > 0 and table.concat(invItems, "\n") or "none"
    local desc = table.concat({
        "** " .. accountName .. " **",
        "",
        "** weather: **",
        findActiveWeather() .. " | end: " .. findWeatherEndTime(),
        "",
        "** seed and gear **",
        table.concat(buildPairedBuyLines(8), "\n"),
        "",
        "** pet **",
        table.concat(buildPetBuyLines(), "\n"),
        "",
        "** inventory **",
        invText,
        "",
        "sheckles amount: " .. tostring(getSheckles()),
        "fruit steal: " .. buildStolenFruitText(),
    }, "\n")
    return {
        username = "NTMT HUB",
        embeds = {{
            title = "NTMT HUB | Grow a Garden 2",
            description = desc,
            color = 5763719,
            timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
        }},
    }
end

local function sendWebhook(reason)
    if not webhookUrl or webhookUrl == "" or not webhookUrl:lower():find("discord") then
        notify("Webhook", "Invalid webhook URL", "circle-x", 3)
        return false
    end
    local status = universalHttpPost(webhookUrl, jsonEncode(buildEmbed()))
    return status >= 200 and status < 300
end

local function hopRandomServer()
    local placeId = game.PlaceId
    local url = string.format("https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=100", placeId)
    local ok, body = pcall(function() return universalHttpGet(url) end)
    if not ok or not body then return false end
    local ok2, data = pcall(function() return Services.HttpService:JSONDecode(body) end)
    if not ok2 or type(data) ~= "table" then return false end
    local candidates = {}
    for _, s in ipairs(data.data or {}) do
        if s.id and s.id ~= game.JobId then table.insert(candidates, s.id) end
    end
    if #candidates == 0 then return false end
    pcall(function()
        Services.TeleportService:TeleportToPlaceInstance(placeId, candidates[math.random(1, #candidates)], LocalPlayer)
    end)
    return true
end

local function joinJobId(jobId)
    if not jobId or #jobId < 10 then return false end
    local payload = string.format(
        'game:GetService("TeleportService"):TeleportToPlaceInstance(%d, %q, game:GetService("Players").LocalPlayer)',
        game.PlaceId, jobId
    )
    if queue_on_teleport then pcall(queue_on_teleport, payload)
    elseif syn and syn.queue_on_teleport then pcall(syn.queue_on_teleport, payload) end
    return pcall(function()
        Services.TeleportService:TeleportToPlaceInstance(game.PlaceId, jobId, LocalPlayer)
    end)
end

