local BUY_SEED_NAMES     = { "BuySeedStock","Buy_Seed","BuySeed","PurchaseSeedStock","PurchaseSeed","BuySeed_RE" }
local BUY_GEAR_NAMES     = { "BuyGearStock","Buy_Gear","BuyGear","PurchaseGearStock","PurchaseGear","BuyGear_RE" }
local BUY_SEED_NET_PATHS = {
    {"Shop","BuySeedStock"},{"Shop","BuySeed"},{"Shop","Buy_Seed"},{"Shop","BuySeed_RE"},
    {"Garden","BuySeed"},{"Garden","BuySeedStock"},{"Garden","Buy_Seed"},
}
local BUY_GEAR_NET_PATHS = {
    {"Shop","BuyGearStock"},{"Shop","BuyGear"},{"Shop","Buy_Gear"},{"Shop","BuyGear_RE"},
    {"Garden","BuyGear"},{"Garden","BuyGearStock"},{"Garden","Buy_Gear"},
}

local function fireOne(rem, name)
    if not rem then return false end
    if rem:IsA("RemoteEvent") then
        return pcall(function() rem:FireServer(name) end)
    elseif rem:IsA("RemoteFunction") then
        return pcall(function() rem:InvokeServer(name) end)
    end
    return false
end

local function bruteForceBuy(name, remoteNames, netPaths)
    local fired = 0
    local GE = Services.ReplicatedStorage:FindFirstChild("GameEvents")
    if GE then
        for _, n in ipairs(remoteNames) do
            local r = GE:FindFirstChild(n)
            if r and (r:IsA("RemoteEvent") or r:IsA("RemoteFunction")) then
                if fireOne(r, name) then fired += 1 end
            end
        end
    end
    if Networking then
        for _, path in ipairs(netPaths) do
            local cat = Networking[path[1]]
            local fn  = cat and cat[path[2]]
            if fn and type(fn) == "table" and fn.Fire then
                if pcall(function() fn:Fire(name) end) then fired += 1 end
            end
        end
    end
    return fired
end

local function buySeed(name, amount)
    for _ = 1, (amount or 1) do
        bruteForceBuy(name, BUY_SEED_NAMES, BUY_SEED_NET_PATHS)
    end
end

local function buyGear(name, amount)
    for _ = 1, (amount or 1) do
        bruteForceBuy(name, BUY_GEAR_NAMES, BUY_GEAR_NET_PATHS)
    end
end

