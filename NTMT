local function buildSeedStockText()
    local items = getSeedShopItems()
    if not items then return "(Khong tim thay StockValues.SeedShop)" end
    local list = {}
    for _, val in ipairs(items:GetChildren()) do
        if val:IsA("ValueBase") then
            local stock = getSeedRemainingStock(val.Name)
            if stock > 0 then
                table.insert(list, { name = val.Name, stock = stock, cost = getSeedCost(val.Name) })
            end
        end
    end
    table.sort(list, function(a, b) return a.stock > b.stock end)
    local lines = {}
    local maxShow = math.min(#list, 15)
    for i = 1, maxShow do
        local it = list[i]
        table.insert(lines, ("%s x%d | %s"):format(it.name, it.stock, it.cost and (tostring(it.cost) .. " sheckles") or "?"))
    end
    if #list > maxShow then
        table.insert(lines, ("... +%d seed khac"):format(#list - maxShow))
    end
    if #lines == 0 then return "(Het stock seed)" end
    return table.concat(lines, "\n")
end

