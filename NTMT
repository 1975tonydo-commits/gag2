local function sellInventory()
    local GameEvents = Services.ReplicatedStorage:FindFirstChild("GameEvents")
    if not GameEvents then return false end

    local candidates = { "Sell_Inventory", "SellInventory", "Sell_All", "SellAll", "Sell" }
    for _, name in ipairs(candidates) do
        local rem = GameEvents:FindFirstChild(name)
        if rem then
            local ok = pcall(function()
                if rem:IsA("RemoteEvent") then
                    rem:FireServer()
                else
                    rem:InvokeServer()
                end
            end)
            if ok then return true end
        end
    end
    return false
end

