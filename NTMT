-- Lấy remote harvest (thử nhiều tên)
local function getHarvestRemote()
    local GE = Services.ReplicatedStorage:FindFirstChild("GameEvents")
    if not GE then return nil end
    local names = {
        "SummerHarvestRemoteEvent",
        "HarvestRemoteEvent",
        "Harvest_RE",
        "Collect_Fruit",
        "CollectFruit",
        "Harvest",
    }
    for _, n in ipairs(names) do
        local r = GE:FindFirstChild(n)
        if r then return r, n end
    end
    return nil
end

local function fireHarvestRemote(arg)
    local rem, name = getHarvestRemote()
    if not rem then return false end
    local ok = pcall(function()
        if rem:IsA("RemoteEvent") then
            rem:FireServer(arg)
        else
            rem:InvokeServer(arg)
        end
    end)
    if debugHarvest then
        print("[Harvest] fire", name, "arg=", arg, "ok=", ok)
    end
    return ok
end

-- Cách REMOTE: gửi "SubmitAllPlants" - harvest tất cả cùng lúc
local function harvestRemoteAll()
    return fireHarvestRemote("SubmitAllPlants")
end

-- Cách PROXIMITY/TOUCH: tới gần fruit và trigger
local function harvestSingleFruit(fruit)
    local part = getFruitPart(fruit)
    if not part then return false end

    -- Teleport HRP gần fruit (nhiều game check khoảng cách trên server)
    local hrp = getHRP()
    if not hrp then return false end

    local origCFrame = hrp.CFrame
    pcall(function()
        hrp.CFrame = CFrame.new(part.Position + Vector3.new(0, 3, 0))
    end)

    -- Đợi 1 frame để server nhận vị trí
    task.wait(0.05)

    local fired = false

    -- 1. ProximityPrompt
    local prompt = fruit:FindFirstChildWhichIsA("ProximityPrompt", true)
    if prompt and fireproximityprompt then
        pcall(fireproximityprompt, prompt, 1)
        fired = true
    end

    -- 2. RemoteEvent với fruit làm tham số
    if not fired then
        fireHarvestRemote(fruit)
        fired = true
    end

    -- 3. firetouchinterest
    if firetouchinterest then
        pcall(firetouchinterest, hrp, part, 0)
        pcall(firetouchinterest, hrp, part, 1)
    end

    if teleportBack then
        task.wait(0.05)
        pcall(function() hrp.CFrame = origCFrame end)
    end

    return fired
end

