-- Loop Auto Harvest
task.spawn(function()
    while true do
        local interval = harvestInterval
        if genv.ftgs_AutoHarvest then
            local ok, err = pcall(function()
                if HarvestMode == "Remote" then
                    harvestRemoteAll()
                elseif HarvestMode == "Teleport" then
                    for _, farm in ipairs(getOwnedFarms()) do
                        if not genv.ftgs_AutoHarvest then break end
                        for _, fruit in ipairs(getFruitsInFarm(farm)) do
                            if not genv.ftgs_AutoHarvest then break end
                            harvestSingleFruit(fruit)
                            task.wait(0.05)
                        end
                    end
                else -- Combined
                    harvestRemoteAll()
                    for _, farm in ipairs(getOwnedFarms()) do
                        if not genv.ftgs_AutoHarvest then break end
                        for _, fruit in ipairs(getFruitsInFarm(farm)) do
                            if not genv.ftgs_AutoHarvest then break end
                            harvestSingleFruit(fruit)
                            task.wait(0.05)
                        end
                    end
                end
            end)
            if not ok and debugHarvest then warn("[Harvest loop]", err) end
        end
        task.wait(interval)
    end
end)

-- Loop Auto Sell
task.spawn(function()
    while true do
        task.wait(sellInterval)
        if genv.ftgs_AutoSell then
            pcall(sellInventory)
        end
    end
end)

