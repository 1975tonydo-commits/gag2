local function universalHttpPost(url, jsonBody)
    local req = (syn and syn.request) or (http and http.request) or http_request or request or (fluxus and fluxus.request)
    if req then
        local res = req({
            Url = url, Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = jsonBody,
        })
        return res and (res.StatusCode or res.Status or 0)
    end
    local ok = pcall(function()
        Services.HttpService:PostAsync(url, jsonBody, Enum.HttpContentType.ApplicationJson)
    end)
    return ok and 200 or 0
end

local function jsonEncode(t)
    local ok, s = pcall(function() return Services.HttpService:JSONEncode(t) end)
    return ok and s or "{}"
end

