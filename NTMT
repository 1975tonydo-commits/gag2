local function cachePlantAreas()
    clearTable(plantAreas)
    local plot = getCachedOwnedPlot()
    if not plot then return end
    local visual = plot:FindFirstChild("Visual")
    if not visual then return end
    for _, col in ipairs(visual:GetChildren()) do
        if col.Name:match("^PlantAreaColumn") then
            for _, part in ipairs(col:GetChildren()) do
                if part:IsA("BasePart") then
                    table.insert(plantAreas, part.Position)
                end
            end
        end
    end
    if #plantAreas == 0 then
        local ref = plot:FindFirstChild("PlotSizeReference")
        if ref and ref:IsA("BasePart") then
            local center = ref.Position
            local size = ref.Size
            for x = -size.X / 2 + 2, size.X / 2 - 2, 4 do
                for z = -size.Z / 2 + 2, size.Z / 2 - 2, 4 do
                    table.insert(plantAreas, center + Vector3.new(x, 0, z))
                end
            end
        end
    end
end

