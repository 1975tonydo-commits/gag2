    for name, amt in pairs(BoughtGears) do
        if amt > 0 then table.insert(gearLines, ("• %s x%d"):format(name, amt)) end
    end
    if #gearLines == 0 then table.insert(gearLines, "_(chua mua gear nao)_") end

