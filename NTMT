local PURCHASE_METHODS = { "Fire", "FireServer", "Send", "Invoke", "InvokeServer" }

local function tryCallPacket(packet, ...)
    if not packet then return false, "nil packet" end
    if type(packet) == "function" then
        local ok, res = pcall(packet, ...)
        return ok, res
    end
    if type(packet) == "table" then
        for _, m in ipairs(PURCHASE_METHODS) do
            local fn = packet[m]
            if type(fn) == "function" then
                local ok, res = pcall(fn, packet, ...)
                if ok then return true, res end
            end
        end
    end
    return false, "no method matched"
end

